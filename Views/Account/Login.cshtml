@model WebbyPoints.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                        <i class="bi bi-box-arrow-in-right fs-3 text-primary"></i>
                    </div>
                    <h2 class="fw-bold">Iniciar sesión</h2>
                    <p class="text-muted">¿No tienes cuenta? <a href="/Account/RegistroPaso1" class="text-primary fw-semibold text-decoration-none">Regístrate aquí</a></p>
                </div>

                <!-- Errores globales -->
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger rounded-3 py-2 small">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <span>@error.ErrorMessage</span>
                        }
                    </div>
                }

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <form asp-action="Login" method="post" class="vstack gap-3">
                        <div>
                            <label class="form-label small fw-bold text-secondary">Correo institucional</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 input-icon-start">
                                    <i class="bi bi-envelope text-muted"></i>
                                </span>
                                <input asp-for="Email" type="email"
                                       class="form-control form-control-wp input-icon-end"
                                       placeholder="ejemplo@@usmp.pe" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 input-icon-start">
                                    <i class="bi bi-lock text-muted"></i>
                                </span>
                                <input asp-for="Password" type="password"
                                       class="form-control form-control-wp input-icon-end"
                                       placeholder="Tu contraseña" />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label small text-muted" for="rememberMe">Recordarme</label>
                        </div>

                        <button type="submit" class="btn btn-wp w-100 mt-2">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                        </button>

                        <div class="divider-text small py-2">o</div>

                        <a href="/Account/RegistroPaso1" class="btn btn-outline-secondary rounded-pill w-100 fw-semibold py-2">
                            <i class="bi bi-person-plus me-2"></i>Crear cuenta nueva
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
