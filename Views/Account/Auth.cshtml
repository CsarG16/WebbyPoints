@{
    Layout = null;
    var initialMode = ViewData["AuthMode"]?.ToString() ?? "register";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>WebbyPoints - Acceso</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/auth.css">
</head>
<body class="auth-body">
<!-- SVG para Curvas Bézier (Soporta responsive con objectBoundingBox) -->
<svg style="width:0;height:0;position:absolute;" aria-hidden="true" focusable="false">
  <defs>
    <clipPath id="wave-register" clipPathUnits="objectBoundingBox">
      <path d="M0,0 L0.45,0 
               C0.48,0.1 0.42,0.2 0.45,0.3
               C0.48,0.4 0.42,0.5 0.45,0.6
               C0.48,0.7 0.42,0.8 0.45,0.9
               C0.46,0.95 0.45,1 0.45,1 
               L0,1 Z" />
    </clipPath>
    <clipPath id="wave-login" clipPathUnits="objectBoundingBox">
      <path d="M1,0 L0.55,0 
               C0.52,0.1 0.58,0.2 0.55,0.3
               C0.52,0.4 0.58,0.5 0.55,0.6
               C0.52,0.7 0.58,0.8 0.55,0.9
               C0.54,0.95 0.55,1 0.55,1 
               L1,1 Z" />
    </clipPath>
  </defs>
</svg>
<div class="auth-container" id="authBox" data-state="@(initialMode == "login" ? "login" : "register-1")">

    <!-- ============ IMAGE PANEL ============ -->
    <div class="auth-image">
        <img src="/images/campus-hero.png" alt="Campus USMP"/>
        <div class="overlay"></div>
        <div class="glass-wrap">
            <div class="glass">
                <div class="d-flex align-items-center gap-3">
                    <div style="width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center">
                        <i data-lucide="zap" class="text-white" style="width: 20px; height: 20px; fill: white;"></i>
                    </div>
                    <div>
                        <div class="fw-bold small">+500 estudiantes activos</div>
                        <div style="font-size:.72rem;opacity:.7">Comunidad USMP en crecimiento</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============ PANEL: REGISTRO PASO 1 ============ -->
    <div class="auth-panel panel-r @(initialMode != "login" ? "active" : "")" id="panel-register-1">
        <div class="auth-nav">
            <a href="/" class="brand">Webby<span>Points</span></a>
            <a href="/" class="nl">Inicio</a>
            <a href="javascript:void(0)" class="nl" onclick="switchTo('login')">Ingresar</a>
        </div>
        <div style="width:100%;max-width:480px">
            <div class="steps"><div class="dot on"></div><div class="dot"></div></div>
            <p class="text-uppercase text-muted small fw-bold mb-1" style="letter-spacing:2px;font-size:.72rem">Empieza gratis</p>
            <h1 class="fw-black mb-1" style="font-size:2.1rem">Crea tu cuenta<span style="color:#1A4BDE">.</span></h1>
            <p class="text-muted mb-4">¿Ya tienes cuenta? <a href="javascript:void(0)" onclick="switchTo('login')" class="text-decoration-none fw-semibold" style="color:#1A4BDE">Inicia sesión</a></p>
            <div class="err-box" id="err1"><i data-lucide="alert-triangle" class="me-2" style="width: 16px; height: 16px;"></i><span></span></div>
            <form id="formReg1" onsubmit="return false">
                @Html.AntiForgeryToken()
                <div class="d-flex gap-3">
                    <div class="fg flex-grow-1">
                        <input name="Nombre" type="text" placeholder="x" id="r-nom" required/>
                        <label for="r-nom">Nombre completo</label><i data-lucide="user" class="fi"></i>
                    </div>
                    <div class="fg" style="width:130px">
                        <input name="Edad" type="number" placeholder="x" id="r-age" required min="15" max="99"/>
                        <label for="r-age">Edad</label><i data-lucide="calendar" class="fi"></i>
                    </div>
                </div>
                <div class="fg">
                    <input name="Email" type="email" placeholder="x" id="r-email" required/>
                    <label for="r-email">Correo institucional</label><i data-lucide="mail" class="fi"></i>
                </div>
                <div class="d-flex gap-3">
                    <div class="fg flex-grow-1">
                        <input name="Universidad" type="text" value="USMP" id="r-uni" readonly style="background: #f1f5f9; cursor: not-allowed; color: #475569;" required/>
                        <label for="r-uni">Universidad</label><i data-lucide="building" class="fi"></i>
                    </div>
                    <div class="fg flex-grow-1">
                        <select name="Carrera" id="r-car" required style="width: 100%; padding: 1rem 3rem 1rem 1rem; border: 1.5px solid #e2e8f0; border-radius: 0.75rem; font-size: 0.95rem; background: #f8fafc; outline: none; color: #1e293b; appearance: none; -webkit-appearance: none; cursor: pointer; transition: all 0.25s ease; height: 50px;">
                            <option value="" disabled selected hidden>Selecciona tu carrera</option>
                            <option value="Ingenieria de Sistemas">Ingeniería de Sistemas</option>
                            <option value="Derecho">Derecho</option>
                            <option value="Medicina">Medicina</option>
                            <option value="Administracion">Administración</option>
                            <option value="Psicologia">Psicología</option>
                        </select>
                        <label for="r-car" style="top: -.1rem; left: .75rem; font-size: .72rem; color: #94a3b8; font-weight: 600; background: #fff; pointer-events: none;">Carrera</label>
                        <i data-lucide="graduation-cap" class="fi" style="pointer-events: none;"></i>
                    </div>
                </div>
                <div class="d-flex gap-3">
                    <div class="fg flex-grow-1">
                        <input name="Password" type="password" placeholder="x" id="r-pw" required minlength="6"/>
                        <label for="r-pw">Contraseña</label>
                        <i data-lucide="eye" class="fi tog" data-target="r-pw" style="pointer-events: auto;"></i>
                    </div>
                    <div class="fg flex-grow-1">
                        <input name="ConfirmarPassword" type="password" placeholder="x" id="r-cpw" required/>
                        <label for="r-cpw">Confirmar</label>
                        <i data-lucide="eye" class="fi tog" data-target="r-cpw" style="pointer-events: auto;"></i>
                    </div>
                </div>
                <div class="d-flex gap-3 mt-3">
                    <a href="/" class="btn-alt text-center d-inline-flex align-items-center justify-content-center gap-2"><i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>Inicio</a>
                    <button type="button" class="btn-main flex-grow-1 d-inline-flex align-items-center justify-content-center gap-2" onclick="goToStep2()">Siguiente <i data-lucide="arrow-right" style="width: 16px; height: 16px;"></i></button>
                </div>
            </form>
            <p class="text-muted mt-4 mb-0" style="font-size:.75rem">&copy; 2026 Webby Points · USMP</p>
        </div>
    </div>

    <!-- ============ PANEL: REGISTRO PASO 2 ============ -->
    <div class="auth-panel panel-r" id="panel-register-2">
        <div class="auth-nav">
            <a href="/" class="brand">Webby<span>Points</span></a>
            <a href="/" class="nl">Inicio</a>
            <a href="javascript:void(0)" class="nl" onclick="switchTo('login')">Ingresar</a>
        </div>
        <div style="width:100%;max-width:680px">
            <div class="steps"><div class="dot on"></div><div class="dot on"></div></div>
            <p class="text-uppercase text-muted small fw-bold mb-1" style="letter-spacing:2px;font-size:.72rem">Casi listo</p>
            <h1 class="fw-black mb-1" style="font-size:2.1rem">Elige tus intereses<span style="color:#1A4BDE">.</span></h1>
            <p class="text-muted mb-4">Selecciona las categorías que más te gusten.</p>
            <div class="err-box" id="err2"><i data-lucide="alert-triangle" class="me-2" style="width: 16px; height: 16px;"></i><span></span></div>
            <form id="formReg2" onsubmit="return false">
                <div class="row g-3 mb-3">
                    @{
                        var cats = new[]{
                            new{I="Gym",N="Gimnasio",Ic="dumbbell"},
                            new{I="Cafe",N="Cafés",Ic="coffee"},
                            new{I="Study",N="Estudiar",Ic="book-open"},
                            new{I="Food",N="Comida",Ic="utensils"},
                            new{I="Parks",N="Parques",Ic="trees"},
                            new{I="Bares",N="Bares",Ic="glass-water"},
                            new{I="Gaming",N="Gaming",Ic="gamepad-2"},
                            new{I="Cine",N="Cine",Ic="film"},
                            new{I="Rest",N="Restaurantes",Ic="store"}
                        };
                    }
                    @foreach(var c in cats){
                        <div class="col-6 col-sm-4 col-lg-3">
                            <input type="checkbox" name="CategoriasFavoritas" value="@c.N" id="@c.I" class="ci d-none"/>
                            <label for="@c.I" class="cc h-100 d-flex flex-column align-items-center justify-content-center">
                                <i data-lucide="@c.Ic" class="ico mb-2" style="width: 24px; height: 24px; stroke: #94a3b8; stroke-width: 2px;"></i>
                                <span class="fw-bold cn" style="font-size:.82rem;color:#475569">@c.N</span>
                                <i data-lucide="check-circle" class="cb" style="width: 16px; height: 16px;"></i>
                            </label>
                        </div>
                    }
                </div>
                <p class="text-muted small mb-3 d-inline-flex align-items-center gap-1"><i data-lucide="info" style="width: 14px; height: 14px;"></i>Mínimo 2 categorías. <span id="counter" class="fw-bold" style="color:#1A4BDE">0 seleccionadas</span></p>
                <div class="d-flex gap-3">
                    <button type="button" class="btn-alt d-inline-flex align-items-center gap-2" onclick="switchTo('register-1')"><i data-lucide="arrow-left" style="width: 16px; height: 16px;"></i>Atrás</button>
                    <button type="button" class="btn-main flex-grow-1 d-inline-flex align-items-center justify-content-center gap-2" onclick="submitRegistro()" id="btnFinalizar"><i data-lucide="check" style="width: 16px; height: 16px;"></i>Finalizar registro</button>
                </div>
            </form>
            <p class="text-muted mt-4 mb-0" style="font-size:.75rem">&copy; 2026 Webby Points · USMP</p>
        </div>
    </div>

    <!-- ============ PANEL: LOGIN ============ -->
    <div class="auth-panel panel-l @(initialMode == "login" ? "active" : "")" id="panel-login">
        <div class="auth-nav">
            <a href="/" class="brand">Webby<span>Points</span></a>
            <a href="/" class="nl">Inicio</a>
            <a href="javascript:void(0)" class="nl" onclick="switchTo('register-1')">Registrarse</a>
        </div>
        <div style="width:100%;max-width:420px">
            <p class="text-uppercase text-muted small fw-bold mb-1" style="letter-spacing:2px;font-size:.72rem">Bienvenido de vuelta</p>
            <h1 class="fw-black mb-1" style="font-size:2.1rem">Inicia sesión<span style="color:#1A4BDE">.</span></h1>
            <p class="text-muted mb-4">¿No tienes cuenta? <a href="javascript:void(0)" onclick="switchTo('register-1')" class="text-decoration-none fw-semibold" style="color:#1A4BDE">Regístrate gratis</a></p>
            <div class="err-box" id="errLogin"><i data-lucide="alert-triangle" class="me-2" style="width: 16px; height: 16px;"></i><span></span></div>
            <form id="formLogin" onsubmit="return false">
                @Html.AntiForgeryToken()
                <div class="fg">
                    <input name="Email" type="email" placeholder="x" id="l-email" required/>
                    <label for="l-email">Correo institucional</label><i data-lucide="mail" class="fi"></i>
                </div>
                <div class="fg">
                    <input name="Password" type="password" placeholder="x" id="l-pw" required/>
                    <label for="l-pw">Contraseña</label>
                    <i data-lucide="eye" class="fi tog" data-target="l-pw" style="pointer-events: auto;"></i>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="rem" style="border-radius:4px">
                    <label class="form-check-label small text-muted" for="rem">Recordarme</label>
                </div>
                <button type="button" class="btn-main w-100 mb-3 d-inline-flex align-items-center justify-content-center gap-2" onclick="submitLogin()" id="btnLogin"><i data-lucide="log-in" style="width: 16px; height: 16px;"></i>Entrar</button>
                <div class="sep small">o</div>
                <button type="button" class="btn-alt w-100 d-inline-flex align-items-center justify-content-center gap-2" onclick="switchTo('register-1')"><i data-lucide="user-plus" style="width: 16px; height: 16px;"></i>Crear cuenta nueva</button>
            </form>
            <p class="text-muted mt-4 mb-0" style="font-size:.75rem">&copy; 2026 Webby Points · USMP</p>
        </div>
    </div>
</div>

<!-- Success toast -->
<div class="toast-ok d-inline-flex align-items-center gap-2" id="toast"><i data-lucide="check-circle" style="width: 20px; height: 20px;"></i><span></span></div>

<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@latest"></script>
<script>
document.addEventListener("DOMContentLoaded", function () {
    lucide.createIcons();
});

// ========== PANEL SWITCHING ==========
function switchTo(state) {
    const box = document.getElementById('authBox');
    // Remove active from all panels
    document.querySelectorAll('.auth-panel').forEach(p => p.classList.remove('active'));
    // Set new state (drives CSS for image position + wave)
    box.dataset.state = state;
    // Determine delay: same-side = short, cross-side = longer
    const isSameSide = (box._prev || '').startsWith('register') && state.startsWith('register');
    const delay = isSameSide ? 150 : 400;
    setTimeout(() => {
        document.getElementById('panel-' + state).classList.add('active');
    }, delay);
    box._prev = state;
}

// ========== STEP 1 → STEP 2 (client-side validation) ==========
function goToStep2() {
    const form = document.getElementById('formReg1');
    const errBox = document.getElementById('err1');
    // Basic HTML5 validation
    if (!form.checkValidity()) {
        form.reportValidity();
        return;
    }
    // Validar correo institucional
    const email = form.querySelector('[name="Email"]').value.trim().toLowerCase();
    if (!email.endsWith('@@usmp.pe')) {
        showErr(errBox, 'Debes ingresar un correo institucional válido de la USMP (@@usmp.pe).');
        return;
    }
    // Check passwords match
    const pw = form.querySelector('[name="Password"]').value;
    const cpw = form.querySelector('[name="ConfirmarPassword"]').value;
    if (pw !== cpw) {
        showErr(errBox, 'Las contraseñas no coinciden.');
        return;
    }
    hideErr(errBox);
    switchTo('register-2');
}

// ========== SUBMIT REGISTRO (AJAX) ==========
async function submitRegistro() {
    const btn = document.getElementById('btnFinalizar');
    const errBox = document.getElementById('err2');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creando cuenta...';

    // Build FormData from both steps
    const fd = new FormData();
    const f1 = document.getElementById('formReg1');
    new FormData(f1).forEach((v, k) => fd.append(k, v));
    // Categories from step 2
    document.querySelectorAll('.ci:checked').forEach(cb => {
        fd.append('CategoriasFavoritas', cb.value);
    });

    try {
        const res = await fetch('/Account/RegistroAjax', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            showToast('¡Cuenta creada! Redirigiendo...');
            setTimeout(() => window.location.href = data.redirect, 1200);
        } else {
            showErr(errBox, data.errors?.join(' · ') || 'Error al registrar.');
            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="check" style="width: 16px; height: 16px;"></i>Finalizar registro';
            lucide.createIcons();
        }
    } catch {
        showErr(errBox, 'Error de conexión. Intenta de nuevo.');
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="check" style="width: 16px; height: 16px;"></i>Finalizar registro';
        lucide.createIcons();
    }
}

// ========== SUBMIT LOGIN (AJAX) ==========
async function submitLogin() {
    const btn = document.getElementById('btnLogin');
    const errBox = document.getElementById('errLogin');
    const form = document.getElementById('formLogin');
    if (!form.checkValidity()) { form.reportValidity(); return; }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Ingresando...';

    const fd = new FormData(form);
    try {
        const res = await fetch('/Account/LoginAjax', { method: 'POST', body: fd });
        const data = await res.json();
        if (data.success) {
            showToast('¡Bienvenido de vuelta!');
            setTimeout(() => window.location.href = data.redirect, 1000);
        } else {
            showErr(errBox, data.errors?.join(' · ') || 'Credenciales incorrectas.');
            btn.disabled = false;
            btn.innerHTML = '<i data-lucide="log-in" style="width: 16px; height: 16px;"></i>Entrar';
            lucide.createIcons();
        }
    } catch {
        showErr(errBox, 'Error de conexión.');
        btn.disabled = false;
        btn.innerHTML = '<i data-lucide="log-in" style="width: 16px; height: 16px;"></i>Entrar';
        lucide.createIcons();
    }
}

// ========== HELPERS ==========
function showErr(el, msg) { el.querySelector('span').textContent = msg; el.classList.add('show'); }
function hideErr(el) { el.classList.remove('show'); }
function showToast(msg) {
    const t = document.getElementById('toast');
    t.querySelector('span').textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 3000);
}

// Toggle password visibility (Lucide dynamic redraw - Event Delegation)
document.addEventListener('click', function(e) {
    const tog = e.target.closest('.tog');
    if (!tog) return;
    
    e.preventDefault();
    const inp = document.getElementById(tog.getAttribute('data-target'));
    if (!inp) return;
    
    const isPassword = inp.type === 'password';
    inp.type = isPassword ? 'text' : 'password';
    tog.setAttribute('data-lucide', isPassword ? 'eye-off' : 'eye');
    lucide.createIcons();
});

// Category counter
document.querySelectorAll('.ci').forEach(cb => {
    cb.addEventListener('change', () => {
        const n = document.querySelectorAll('.ci:checked').length;
        document.getElementById('counter').textContent = n + ' seleccionada' + (n !== 1 ? 's' : '');
    });
});
</script>
</body>
</html>
