@model WebbyPoints.Models.ViewModels.RegistroViewModel

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Webby Points</title>
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .bg-custom-blue { background-color: #1A4BDE; }
        .rounded-sidebar { border-top-right-radius: 3rem; border-bottom-right-radius: 3rem; }
        .form-control-custom { 
            background-color: #f8fafc; 
            border: none; 
            padding: 0.75rem 1rem; 
            border-radius: 1rem;
        }
        .form-control-custom:focus {
            background-color: #f1f5f9;
            box-shadow: 0 0 0 0.25rem rgba(26, 75, 222, 0.1);
        }
        .btn-custom {
            background-color: #1A4BDE;
            border-radius: 1rem;
            padding: 1rem;
            font-weight: 700;
            transition: all 0.2s;
        }
        .btn-custom:hover {
            background-color: #163eb8;
            transform: translateY(-2px);
            box-shadow: 0 0.5rem 1rem rgba(26, 75, 222, 0.2);
        }
    </style>
</head>
<body class="bg-light">
    <div class="container-fluid p-0 overflow-hidden">
        <div class="row g-0 min-vh-100">
            
            <!-- Sidebar Informativa -->
            <div class="col-md-4 bg-custom-blue d-none d-md-flex flex-column justify-content-center align-items-center p-5 text-white rounded-sidebar shadow-lg z-1">
                <div class="text-center">
                    <h2 class="display-5 fw-bold mb-3">Completa tu perfil</h2>
                    <p class="lead opacity-75">Cuéntanos un poco sobre ti para personalizar tu experiencia en Webby Points.</p>
                </div>
            </div>

            <!-- Formulario -->
            <div class="col-md-8 d-flex justify-content-center align-items-center p-4 p-md-5">
                <div class="w-100 shadow-sm p-4 p-md-0 rounded-4 bg-white bg-md-transparent" style="max-width: 500px;">
                    <p class="text-uppercase tracking-wider text-muted small fw-bold mb-2">Paso 1 de 2 — Información personal</p>
                    <h3 class="fw-bold text-dark mb-4">Información personal</h3>

                    <form asp-action="RegistroPaso1" method="post" class="vstack gap-3">
                        
                        <div class="d-flex flex-column align-items-center mb-4">
                            <div class="rounded-circle bg-light border border-dashed d-flex align-items-center justify-content-center mb-2" style="width: 90px; height: 90px;">
                                <i class="bi bi-plus-lg text-muted fs-2"></i>
                            </div>
                            <button type="button" class="btn btn-link btn-sm text-decoration-none fw-medium">Sube tu foto de perfil</button>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">Nombre completo</label>
                            <input asp-for="Nombre" class="form-control form-control-custom" placeholder="Ej: César Paredes" />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">Correo institucional</label>
                            <input asp-for="Email" type="email" class="form-control form-control-custom" placeholder="usuario@upc.edu.pe" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-secondary">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control form-control-custom" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-secondary">Confirmar</label>
                                <input asp-for="ConfirmarContraseña" type="password" class="form-control form-control-custom" />
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-4">
                                <label class="form-label small fw-bold text-secondary">Edad</label>
                                <input asp-for="Edad" class="form-control form-control-custom" placeholder="20" />
                            </div>
                            <div class="col-8">
                                <label class="form-label small fw-bold text-secondary">Universidad</label>
                                <input asp-for="Universidad" class="form-control form-control-custom" placeholder="Ej: UPC" />
                            </div>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">¿Qué carrera estudias?</label>
                            <input asp-for="Carrera" class="form-control form-control-custom" />
                        </div>

                        <button type="submit" class="btn btn-primary btn-custom text-white border-0 mt-4">
                            Siguiente
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
>
</html>