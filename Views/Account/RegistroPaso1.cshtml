@model WebbyPoints.Models.ViewModels.RegistroViewModel

@{
    Layout = null; 
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - Webby Points</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 antialiased">
    <div class="flex flex-col md:flex-row min-h-screen">
        
        <div class="hidden md:flex md:w-1/3 bg-[#1A4BDE] flex-col justify-center items-center p-12 text-white rounded-r-[3rem] shadow-2xl">
            <div class="text-center">
                <h2 class="text-4xl font-bold mb-4">Completa tu perfil</h2>
                <p class="text-blue-100 text-lg opacity-80">Cuéntanos un poco sobre ti para personalizar tu experiencia en Webby Points.</p>
            </div>
        </div>

        <div class="flex-1 flex justify-center items-center p-6 md:p-12">
            <div class="w-full max-w-lg bg-white md:bg-transparent p-8 md:p-0 rounded-3xl shadow-xl md:shadow-none">
                <p class="text-slate-400 text-sm font-semibold uppercase tracking-wider mb-2">Paso 1 de 2 — Información personal</p>
                <h3 class="text-3xl font-bold text-slate-800 mb-8">Información personal</h3>

                <form asp-action="RegistroPaso1" method="post" class="space-y-5">
                    
                    <div class="flex flex-col items-center mb-8">
                        <div class="w-24 h-24 rounded-full bg-slate-100 border-2 border-dashed border-slate-300 flex items-center justify-center mb-2">
                            <svg class="w-10 h-10 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        </div>
                        <button type="button" class="text-blue-600 text-sm font-medium hover:underline">Sube tu foto de perfil</button>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Nombre completo</label>
                        <input asp-for="Nombre" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" placeholder="Ej: César Paredes" />
                        <span asp-validation-for="Nombre" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">Correo institucional</label>
                        <input asp-for="Email" type="email" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" placeholder="usuario@upc.edu.pe" />
                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Contraseña</label>
                            <input asp-for="Password" type="password" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" />
                        </div>
                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Confirmar</label>
                            <input asp-for="ConfirmarContraseña" type="password" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" />
                        </div>
                    </div>

                    <div class="grid grid-cols-3 gap-4">
                        <div class="col-span-1">
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Edad</label>
                            <input asp-for="Edad" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" placeholder="20" />
                        </div>
                        <div class="col-span-2">
                            <label class="block text-sm font-semibold text-slate-700 mb-1">Universidad</label>
                            <input asp-for="Universidad" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" placeholder="Ej: UPC" />
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-slate-700 mb-1">¿Qué carrera estudias?</label>
                        <input asp-for="Carrera" class="w-full px-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-2 focus:ring-blue-500 transition-all outline-none" />
                    </div>

                    <button type="submit" class="w-full bg-[#1A4BDE] hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-200 transition-all transform hover:scale-[1.02] active:scale-[0.98] mt-6">
                        Siguiente
                    </button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>