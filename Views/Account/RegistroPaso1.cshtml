@model WebbyPoints.Models.RegistroViewModel
@{
    ViewData["Title"] = "Registro - Paso 1";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                        <i class="bi bi-person-plus fs-3 text-primary"></i>
                    </div>
                    <span class="badge bg-light text-muted border rounded-pill mb-2">Paso 1 de 2</span>
                    <h2 class="fw-bold">Información personal</h2>
                    <p class="text-muted">Cuéntanos un poco sobre ti para personalizar tu experiencia.</p>
                </div>

                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <form asp-action="RegistroPaso1" method="post" class="vstack gap-3">

                        <div>
                            <label class="form-label small fw-bold text-secondary">Nombre completo</label>
                            <input asp-for="Nombre" class="form-control form-control-wp" placeholder="Ej: César Paredes" />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">Correo institucional</label>
                            <input asp-for="Email" type="email" class="form-control form-control-wp" placeholder="usuario@@usmp.pe" />
                            <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-secondary">Contraseña</label>
                                <input asp-for="Password" type="password" class="form-control form-control-wp" placeholder="Mín. 6 caracteres" />
                                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-secondary">Confirmar</label>
                                <input asp-for="ConfirmarPassword" type="password" class="form-control form-control-wp" />
                                <span asp-validation-for="ConfirmarPassword" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col-4">
                                <label class="form-label small fw-bold text-secondary">Edad</label>
                                <input asp-for="Edad" class="form-control form-control-wp" placeholder="20" />
                                <span asp-validation-for="Edad" class="text-danger small mt-1 d-block"></span>
                            </div>
                            <div class="col-8">
                                <label class="form-label small fw-bold text-secondary">Universidad</label>
                                <input asp-for="Universidad" class="form-control form-control-wp" placeholder="Ej: USMP" />
                                <span asp-validation-for="Universidad" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div>
                            <label class="form-label small fw-bold text-secondary">¿Qué carrera estudias?</label>
                            <input asp-for="Carrera" class="form-control form-control-wp" placeholder="Ej: Ingeniería de Software" />
                            <span asp-validation-for="Carrera" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <button type="submit" class="btn btn-wp w-100 mt-3">
                            Siguiente <i class="bi bi-arrow-right ms-2"></i>
                        </button>

                        <p class="text-center text-muted small mt-2 mb-0">
                            ¿Ya tienes cuenta? <a href="/Account/Login" class="text-primary fw-semibold text-decoration-none">Inicia sesión</a>
                        </p>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>