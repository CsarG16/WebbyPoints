@model WebbyPoints.Models.ViewModels.RegistroViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Webby Points - Tus preferencias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 antialiased">
    <div class="flex flex-col md:flex-row min-h-screen">
        
        <div class="hidden md:flex md:w-1/3 bg-[#1A4BDE] flex-col justify-center items-center p-12 text-white rounded-r-[3rem] shadow-2xl">
            <div class="text-center">
                <i class="bi bi-person-circle text-6xl mb-6 block"></i>
                <h2 class="text-4xl font-bold mb-4">Completa tu perfil</h2>
                <p class="text-blue-100 text-lg opacity-80 leading-relaxed">
                    Cuéntanos un poco sobre ti para personalizar tu experiencia. Esto nos ayudará a recomendarte los mejores lugares según tus intereses.
                </p>
            </div>
        </div>

        <div class="flex-1 p-6 md:p-16 overflow-y-auto">
            <div class="max-w-3xl mx-auto">
                <p class="text-slate-400 text-sm font-semibold uppercase tracking-wider mb-2">Paso 2 de 2 — Preferencias</p>
                <h3 class="text-3xl font-bold text-slate-800 mb-1">Tus preferencias</h3>
                <p class="text-slate-500 mb-10">Selecciona las actividades que más te gusten</p>

                <form asp-action="ConfirmarRegistro" method="post">
                    <input type="hidden" asp-for="Nombre" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Password" />
                    <input type="hidden" asp-for="ConfirmarContraseña" />
                    <input type="hidden" asp-for="Edad" />
                    <input type="hidden" asp-for="Universidad" />
                    <input type="hidden" asp-for="Carrera" />

                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-6">
                        @{
                            var categorias = new[] { 
                                new { Id = "Gym", Nom = "Gimnasio", Icon = "bi-pumping-iron" },
                                new { Id = "Cafe", Nom = "Cafés", Icon = "bi-cup-hot" },
                                new { Id = "Study", Nom = "Estudiar", Icon = "bi-pencil-square" },
                                new { Id = "Food", Nom = "Comida", Icon = "bi-egg-fried" },
                                new { Id = "Parks", Nom = "Parques", Icon = "bi-tree" },
                                new { Id = "Bares", Nom = "Bares", Icon = "bi-glass-margin" },
                                new { Id = "Gaming", Nom = "Gaming", Icon = "bi-controller" },
                                new { Id = "Cine", Nom = "Cine", Icon = "bi-film" },
                                new { Id = "Rest", Nom = "Restaurantes", Icon = "bi-utensils" }
                            };
                        }

                        @foreach (var cat in categorias)
                        {
                            <div class="relative">
                                <input type="checkbox" name="CategoriasFavoritas" value="@cat.Nom" id="@cat.Id" class="peer hidden" />
                                
                                <label for="@cat.Id" 
                                       class="flex flex-col items-center justify-center p-6 bg-white border-2 border-slate-100 rounded-[2rem] cursor-pointer shadow-sm transition-all duration-300
                                              hover:border-blue-200 hover:-translate-y-1 hover:shadow-md
                                              peer-checked:border-[#1A4BDE] peer-checked:bg-blue-50 peer-checked:shadow-inner">
                                    
                                    <i class="bi @cat.Icon text-3xl mb-3 text-slate-400 transition-colors duration-300 peer-checked:text-[#1A4BDE]"></i>
                                    <span class="font-bold text-slate-700 transition-colors duration-300 peer-checked:text-[#1A4BDE]">@cat.Nom</span>
                                </label>
                                
                                <div class="absolute top-3 right-3 opacity-0 peer-checked:opacity-100 transition-opacity">
                                    <i class="bi bi-check-circle-fill text-[#1A4BDE]"></i>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="mt-12 mb-10">
                        <button type="submit" 
                                class="w-full bg-[#1A4BDE] hover:bg-blue-700 text-white font-bold py-4 rounded-2xl shadow-lg shadow-blue-200 transition-all transform hover:scale-[1.01] active:scale-[0.98]">
                            Finalizar registro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</body>
</html>