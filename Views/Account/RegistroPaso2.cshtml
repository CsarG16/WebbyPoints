@model WebbyPoints.Models.RegistroViewModel
@{
    ViewData["Title"] = "Registro - Paso 2";
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 64px; height: 64px;">
                        <i class="bi bi-heart fs-3 text-primary"></i>
                    </div>
                    <span class="badge bg-light text-muted border rounded-pill mb-2">Paso 2 de 2</span>
                    <h2 class="fw-bold">Tus preferencias</h2>
                    <p class="text-muted">Selecciona las actividades que más te gusten para personalizar tus recomendaciones.</p>
                </div>

                <form asp-action="ConfirmarRegistro" method="post">
                    <!-- Hidden fields del paso anterior -->
                    <input type="hidden" asp-for="Nombre" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Password" />
                    <input type="hidden" asp-for="ConfirmarPassword" />
                    <input type="hidden" asp-for="Edad" />
                    <input type="hidden" asp-for="Universidad" />
                    <input type="hidden" asp-for="Carrera" />

                    <div class="row g-3 mb-4">
                        @{
                            var categorias = new[] {
                                new { Id = "Gym",     Nom = "Gimnasio",      Icon = "bi-heart-pulse" },
                                new { Id = "Cafe",    Nom = "Cafés",         Icon = "bi-cup-hot" },
                                new { Id = "Study",   Nom = "Estudiar",      Icon = "bi-pencil-square" },
                                new { Id = "Food",    Nom = "Comida",        Icon = "bi-egg-fried" },
                                new { Id = "Parks",   Nom = "Parques",       Icon = "bi-tree" },
                                new { Id = "Bares",   Nom = "Bares",         Icon = "bi-cup-straw" },
                                new { Id = "Gaming",  Nom = "Gaming",        Icon = "bi-controller" },
                                new { Id = "Cine",    Nom = "Cine",          Icon = "bi-film" },
                                new { Id = "Rest",    Nom = "Restaurantes",  Icon = "bi-shop" }
                            };
                        }

                        @foreach (var cat in categorias)
                        {
                            <div class="col-6 col-sm-4 col-lg-3">
                                <input type="checkbox" name="CategoriasFavoritas" value="@cat.Nom" id="@cat.Id" class="cat-input d-none" />
                                <label for="@cat.Id" class="cat-card h-100 d-flex flex-column align-items-center justify-content-center">
                                    <i class="bi @cat.Icon fs-1 text-secondary mb-2"></i>
                                    <span class="fw-bold text-dark cat-name small">@cat.Nom</span>
                                    <i class="bi bi-check-circle-fill check-badge"></i>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="text-center">
                        <button type="submit" class="btn btn-wp btn-lg px-5">
                            <i class="bi bi-check-lg me-2"></i>Finalizar registro
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>