@model List<WebbyPoints.Models.PuntoInteres>
@{
    ViewData["Title"] = "Explorar";
    var planActual = ViewData["Plan"]?.ToString()?.ToLower() ?? "solo";

    // Configuración visual por tipo de plan
    var config = planActual switch {
        "pareja" => new { Icon = "bi-heart-fill", Color = "danger", Label = "Pareja", Desc = "Momentos especiales" },
        "amigos" => new { Icon = "bi-people-fill", Color = "warning", Label = "Amigos", Desc = "Diversión garantizada" },
        _        => new { Icon = "bi-person-fill", Color = "primary", Label = "Solo", Desc = "Productividad y relax" }
    };
}

<!-- Hero / Selector de Planes -->
<section class="bg-wp-primary text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-7">
                <h1 class="display-5 fw-black mb-3">¿Cambiamos de plan?</h1>
                <p class="lead opacity-75">Selecciona tu vibra de hoy para ajustar las recomendaciones.</p>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Card Plan Solo -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=solo" class="text-decoration-none">
                    <div class="card plan-card border-0 p-4 h-100 shadow-lg @(planActual == "solo" ? "bg-white text-primary scale-up" : "bg-white bg-opacity-10 text-white")">
                        <div class="d-flex align-items-center">
                            <div class="rounded-3 d-flex align-items-center justify-content-center @(planActual == "solo" ? "bg-primary text-white" : "bg-white bg-opacity-20 text-white")" style="width: 50px; height: 50px;">
                                <i class="bi bi-person-fill fs-4"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h6 class="mb-0 fw-bold">Plan solo</h6>
                                <small class="@(planActual == "solo" ? "text-primary opacity-75" : "text-white opacity-50")">Productividad</small>
                            </div>
                            @if(planActual == "solo") { <i class="bi bi-check-circle-fill fs-5"></i> }
                        </div>
                    </div>
                </a>
            </div>

            <!-- Card Plan Pareja -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=pareja" class="text-decoration-none">
                    <div class="card plan-card border-0 p-4 h-100 shadow-lg @(planActual == "pareja" ? "bg-white text-danger scale-up" : "bg-white bg-opacity-10 text-white")">
                        <div class="d-flex align-items-center">
                            <div class="rounded-3 d-flex align-items-center justify-content-center @(planActual == "pareja" ? "bg-danger text-white" : "bg-white bg-opacity-20 text-white")" style="width: 50px; height: 50px;">
                                <i class="bi bi-heart-fill fs-4"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h6 class="mb-0 fw-bold">Plan pareja</h6>
                                <small class="@(planActual == "pareja" ? "text-danger opacity-75" : "text-white opacity-50")">Citas & Relax</small>
                            </div>
                            @if(planActual == "pareja") { <i class="bi bi-check-circle-fill fs-5"></i> }
                        </div>
                    </div>
                </a>
            </div>

            <!-- Card Plan Amigos -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=amigos" class="text-decoration-none">
                    <div class="card plan-card border-0 p-4 h-100 shadow-lg @(planActual == "amigos" ? "bg-white text-warning scale-up" : "bg-white bg-opacity-10 text-white")">
                        <div class="d-flex align-items-center">
                            <div class="rounded-3 d-flex align-items-center justify-content-center @(planActual == "amigos" ? "bg-warning text-white" : "bg-white bg-opacity-20 text-white")" style="width: 50px; height: 50px;">
                                <i class="bi bi-people-fill fs-4"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h6 class="mb-0 fw-bold">Plan amigos</h6>
                                <small class="@(planActual == "amigos" ? "text-warning opacity-75" : "text-white opacity-50")">Diversión</small>
                            </div>
                            @if(planActual == "amigos") { <i class="bi bi-check-circle-fill fs-5"></i> }
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Filtros y Resultados -->
<section class="py-4">
    <div class="container">
        <!-- Toolbar de Búsqueda -->
        <div class="row mb-4">
            <div class="col-lg-12">
                <div class="bg-white p-3 rounded-4 shadow-sm border d-flex flex-wrap gap-3 align-items-center">
                    <div class="flex-grow-1 position-relative">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" class="form-control border-0 bg-light rounded-pill ps-5 py-2" placeholder="Buscar por nombre o categoría...">
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-light rounded-pill px-3 border"><i class="bi bi-sliders me-2"></i>Filtros</button>
                        <select class="form-select border-0 bg-light rounded-pill px-4" style="width: auto;">
                            <option>Más cercanos</option>
                            <option>Mejor calificados</option>
                            <option>Más baratos</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex align-items-center gap-2 mb-4">
            <h3 class="fw-bold mb-0">Recomendaciones para ti</h3>
            <span class="badge bg-@(config.Color)-subtle text-@(config.Color) rounded-pill py-2 px-3">
                <i class="bi @config.Icon me-1"></i>@config.Label
            </span>
        </div>

        <!-- Resultados -->
        @if (Model != null && Model.Count > 0)
        {
            <div class="row g-4">
                @foreach (var punto in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card poi-card bg-white border-0 shadow-sm h-100 rounded-4 overflow-hidden">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(punto.ImagenUrl))
                                {
                                    <img src="@punto.ImagenUrl" class="card-img-top" alt="@punto.Nombre" style="height: 200px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image text-muted fs-1 opacity-25"></i>
                                    </div>
                                }
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-white text-dark shadow-sm py-2 px-3 rounded-pill border">
                                        <i class="bi bi-star-fill text-warning me-1"></i>@punto.Calificacion.ToString("0.0")
                                    </span>
                                </div>
                                <div class="position-absolute bottom-0 start-0 m-3">
                                    <span class="badge bg-@(config.Color) text-white shadow-sm py-2 px-3 rounded-pill">
                                        @punto.Categoria
                                    </span>
                                </div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-2">@punto.Nombre</h5>
                                <p class="text-muted small mb-3 line-clamp-2">@punto.Descripcion</p>
                                
                                <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                                    <div class="small d-flex align-items-center text-muted">
                                        <i class="bi bi-geo-alt me-1"></i>@punto.Distancia km
                                    </div>
                                    <div class="small d-flex align-items-center text-muted">
                                        <i class="bi bi-currency-dollar me-1"></i>@punto.PrecioRango
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="small text-muted">
                                        <i class="bi bi-clock me-1"></i>@(string.IsNullOrEmpty(punto.Horario) ? "9:00 AM - 10:00 PM" : punto.Horario)
                                    </div>
                                    <a href="#" class="btn btn-wp btn-sm px-3 rounded-pill">Ver detalles</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Estado vacío -->
            <div class="text-center py-5 bg-white rounded-5 shadow-sm border mt-4">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                    <i class="bi bi-search fs-1 text-muted opacity-50"></i>
                </div>
                <h3 class="fw-bold mb-2">No encontramos resultados</h3>
                <p class="text-muted mb-4 mx-auto" style="max-width: 450px;">
                    Parece que aún no hay lugares registrados para el plan <strong>@config.Label</strong>. 
                    ¡Ayuda a la comunidad USMP siendo el primero en agregar uno!
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/" class="btn btn-outline-secondary rounded-pill px-4">Volver al inicio</a>
                    <button class="btn btn-wp rounded-pill px-4"><i class="bi bi-plus-lg me-2"></i>Agregar Lugar</button>
                </div>
            </div>
        }
    </div>
</section>

<style>
    .scale-up { transform: scale(1.05); }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .plan-card { transition: all 0.3s ease; }
    .plan-card:hover { transform: translateY(-5px); cursor: pointer; }
    .poi-card { transition: all 0.3s ease; }
    .poi-card:hover { transform: translateY(-8px); box-shadow: 0 1rem 3rem rgba(0,0,0,0.12) !important; }
</style>
