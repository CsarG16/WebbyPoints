@model List<WebbyPoints.Models.PuntoInteres>
@{
    ViewData["Title"] = "Explorar";
    var planActual = ViewData["Plan"]?.ToString()?.ToLower() ?? "todos";

    // Configuración visual por tipo de plan
    var config = planActual switch {
        "pareja" => new { Icon = "bi-heart-fill", Color = "danger", Label = "Pareja", Desc = "Momentos especiales" },
        "amigos" => new { Icon = "bi-people-fill", Color = "warning", Label = "Amigos", Desc = "Diversión garantizada" },
        "solo"   => new { Icon = "bi-person-fill", Color = "primary", Label = "Solo", Desc = "Productividad y relax" },
        _        => new { Icon = "bi-compass-fill", Color = "dark", Label = "Todos los lugares", Desc = "Descubre de todo" }
    };
}

<section class="bg-wp-primary text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-7">
                <h1 class="display-5 fw-black mb-3">¿Cambiamos de plan?</h1>
                <p class="lead opacity-75">Selecciona tu vibra de hoy para ajustar las recomendaciones.</p>
            </div>
            <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
                <a href="/Home/Explorar" class="btn btn-outline-light rounded-pill px-4 @(planActual == "todos" ? "active" : "")">Ver Todos</a>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            @{
                var planes = new[] {
                    new { Id = "solo", Label = "Plan solo", Sub = "Productividad", Icon = "bi-person-fill", ActiveColor = "#0d6efd" },
                    new { Id = "pareja", Label = "Plan pareja", Sub = "Citas & Relax", Icon = "bi-heart-fill", ActiveColor = "#dc3545" },
                    new { Id = "amigos", Label = "Plan amigos", Sub = "Diversión", Icon = "bi-people-fill", ActiveColor = "#ffc107" }
                };
            }

            @foreach (var p in planes)
            {
                var isActive = planActual == p.Id;
                <div class="col-md-4">
                    <a href="/Home/Explorar?plan=@p.Id" class="text-decoration-none">
                        <div class="card plan-card border-0 p-4 h-100 shadow-lg @(isActive ? "bg-white scale-up" : "bg-white bg-opacity-10 text-white")"
                             style="transition: all 0.3s ease; border-radius: 1.5rem;">
                            <div class="d-flex align-items-center">
                                <!-- Contenedor del Icono -->
                                <div class="rounded-3 d-flex align-items-center justify-content-center" 
                                     style="width: 54px; height: 54px; flex-shrink: 0; 
                                            background-color: @(isActive ? p.ActiveColor : "rgba(255,255,255,0.2)");">
                                    <i class="bi @p.Icon fs-4 text-white"></i>
                                </div>
                                
                                <!-- Texto -->
                                <div class="ms-3 flex-grow-1">
                                    <h6 class="mb-0 fw-bold @(isActive ? "text-dark" : "text-white")">@p.Label</h6>
                                    <small class="@(isActive ? "text-muted" : "text-white opacity-75")">@p.Sub</small>
                                </div>

                                <!-- Checkmark si está activo -->
                                @if(isActive) { 
                                    <i class="bi bi-check-circle-fill fs-5" style="color: @p.ActiveColor;"></i> 
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
    
        <div class="row mb-4">
            <div class="col-lg-12">
                <form method="get" action="/Home/Explorar" class="bg-white p-3 rounded-4 shadow-sm border d-flex flex-wrap gap-3 align-items-center">
                    
                    <input type="hidden" name="plan" value="@planActual" />

                    <div class="flex-grow-1 position-relative">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control border-0 bg-light rounded-pill ps-5 py-2" placeholder="Buscar por nombre (Ej: Starbucks) o categoría...">
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-wp rounded-pill px-4 text-white" style="background-color: #0d6efd;">Buscar</button>
                        
                        <select name="sortBy" class="form-select border border-secondary bg-light rounded-pill px-4" style="width: auto;" onchange="this.form.submit()">
                            <option value="">✨ Recomendados</option>
                            <option value="calificacion" selected="@(ViewData["SortBy"]?.ToString() == "calificacion" ? "selected" : null)">⭐ Mejor calificados</option>
                            <option value="cercanos" selected="@(ViewData["SortBy"]?.ToString() == "cercanos" ? "selected" : null)">📍 Más cercanos</option>
                            <option value="baratos" selected="@(ViewData["SortBy"]?.ToString() == "baratos" ? "selected" : null)">💸 Más baratos</option>
                        </select>
                    </div>
                </form>
            </div>
        </div>

        @* ==========================================================
           SECCIÓN: VISTOS RECIENTEMENTE (Sesiones + Redis Cloud)
           Solo aparece si el usuario ya visitó algún punto de interés.
           Los datos vienen de la sesión privada de ESTE usuario,
           que se almacena físicamente en Redis Cloud.
           ========================================================== *@
        @{
            var vistosRecientes = ViewBag.VistosRecientes as List<WebbyPoints.Models.PuntoInteres>;
        }

        @if (vistosRecientes != null && vistosRecientes.Count > 0)
        {
            <div class="vistos-recientes-section rounded-4 p-4 mb-5">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="vistos-icon-wrapper">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Vistos recientemente</h5>
                        <p class="text-muted small mb-0">Lugares que exploraste en esta sesión</p>
                    </div>

                </div>

                <div class="row g-3">
                    @foreach (var punto in vistosRecientes)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <a href="/Home/Detalle/@punto.Id" class="text-decoration-none">
                                <div class="card visto-card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                                    <div class="row g-0 h-100">
                                        <div class="col-12 d-flex align-items-center">
                                            <div class="card-body py-3 px-3">
                                                <h6 class="fw-bold mb-1 text-dark">@punto.Nombre</h6>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill small mb-2">
                                                    @punto.Categoria
                                                </span>
                                                <div class="d-flex align-items-center gap-3 text-muted small">
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i class="bi bi-star-fill text-warning"></i> @punto.Calificacion.ToString("0.0")
                                                    </span>
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i class="bi bi-currency-dollar text-primary"></i> @punto.PrecioRango
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="d-flex align-items-center gap-2 mb-4">
            <h3 class="fw-bold mb-0">Recomendaciones para ti</h3>
            <span class="badge bg-@(config.Color)-subtle text-@(config.Color) rounded-pill py-2 px-3">
                <i class="bi @config.Icon me-1"></i>@config.Label
            </span>
        </div>

        @if (Model != null && Model.Count > 0)
        {
            <div class="row g-4">
                @foreach (var punto in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card poi-card bg-white border-0 shadow-sm h-100 rounded-4 overflow-hidden">
                            <div class="position-relative">
                                @if (!string.IsNullOrEmpty(punto.ImagenUrl))
                                {
                                    <img src="@punto.ImagenUrl" class="card-img-top" alt="@punto.Nombre" style="height: 200px; object-fit: cover;" loading="lazy">
                                }
                                else
                                {
                                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                        <i class="bi bi-image text-muted fs-1 opacity-25"></i>
                                    </div>
                                }
                                <div class="position-absolute top-0 end-0 m-3">
                                    <span class="badge bg-white text-dark shadow-sm py-2 px-3 rounded-pill border">
                                        <i class="bi bi-star-fill text-warning me-1"></i>@punto.Calificacion.ToString("0.0")
                                    </span>
                                </div>
                                <div class="position-absolute bottom-0 start-0 m-3">
                                    <span class="badge bg-@(config.Color == "dark" ? "secondary" : config.Color) text-white shadow-sm py-2 px-3 rounded-pill">
                                        @punto.Categoria
                                    </span>
                                </div>
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-2">@punto.Nombre</h5>
                                <p class="text-muted small mb-3 line-clamp-2">@punto.Descripcion</p>
                                
                                <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
                                    <div class="small d-flex align-items-center text-muted">
                                        <i class="bi bi-geo-alt me-1"></i>@punto.Distancia km
                                    </div>
                                    <div class="small d-flex align-items-center text-muted">
                                        <i class="bi bi-currency-dollar me-1"></i>@punto.PrecioRango
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="small text-muted">
                                        <i class="bi bi-clock me-1"></i>@(string.IsNullOrEmpty(punto.Horario) ? "9:00 AM - 10:00 PM" : punto.Horario)
                                    </div>
                                    <a href="/Home/Detalle/@punto.Id" class="btn btn-wp btn-sm px-3 rounded-pill border border-secondary">Ver detalles</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 bg-white rounded-5 shadow-sm border mt-4">
                <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                    <i class="bi bi-search fs-1 text-muted opacity-50"></i>
                </div>
                <h3 class="fw-bold mb-2">No encontramos resultados</h3>
                <p class="text-muted mb-4 mx-auto" style="max-width: 450px;">
                    Parece que aún no hay lugares registrados para el plan <strong>@config.Label</strong>. 
                    ¡Ayuda a la comunidad USMP siendo el primero en agregar uno!
                </p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/" class="btn btn-outline-secondary rounded-pill px-4">Volver al inicio</a>
                    <button class="btn btn-wp border border-secondary rounded-pill px-4"><i class="bi bi-plus-lg me-2"></i>Agregar Lugar</button>
                </div>
            </div>
        }
    </div>
</section>

<style>
    .scale-up { transform: scale(1.05); }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .plan-card { transition: all 0.3s ease; }
    .plan-card:hover { transform: translateY(-5px); cursor: pointer; }
    .poi-card { transition: all 0.3s ease; }
    .poi-card:hover { transform: translateY(-8px); box-shadow: 0 1rem 3rem rgba(0,0,0,0.12) !important; }

    /* Vistos Recientemente (Sesiones + Redis Cloud) */
    .vistos-recientes-section {
        background: linear-gradient(135deg, #f0f4ff 0%, #e8ecff 100%);
        border: 1px solid rgba(79, 70, 229, 0.1);
    }
    .vistos-icon-wrapper {
        width: 44px;
        height: 44px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.2rem;
        flex-shrink: 0;
    }
    .visto-card {
        transition: all 0.3s ease;
        cursor: pointer;
    }
    .visto-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 0.75rem 2rem rgba(0,0,0,0.1) !important;
    }
</style>