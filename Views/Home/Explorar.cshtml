@model List<WebbyPoints.Models.PuntoInteres>
@{
    ViewData["Title"] = "Explorar";
    var planActual = ViewData["Plan"]?.ToString()?.ToLower() ?? "todos";

    // Configuración visual por tipo de plan
    var config = planActual switch {
        "pareja" => new { Icon = "heart", Color = "danger", Label = "Pareja", Desc = "Momentos especiales" },
        "amigos" => new { Icon = "users", Color = "warning", Label = "Amigos", Desc = "Diversión garantizada" },
        "solo"   => new { Icon = "user", Color = "primary", Label = "Solo", Desc = "Productividad y relax" },
        _        => new { Icon = "compass", Color = "dark", Label = "Todos los lugares", Desc = "Descubre de todo" }
    };

    // Variables de paginación
    var currentPage = Convert.ToInt32(ViewData["CurrentPage"] ?? 1);
    var totalPages = Convert.ToInt32(ViewData["TotalPages"] ?? 1);
    var currentPlan = ViewData["Plan"]?.ToString() ?? "todos";
    var currentSearchTerm = ViewData["SearchTerm"]?.ToString() ?? "";
    var currentSortBy = ViewData["SortBy"]?.ToString() ?? "";
}

<style>
    /* Estilos Premium para la Paginación */
    .pagination-premium {
        background: rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1.5px solid rgba(226, 232, 240, 0.8);
        padding: 0.4rem;
        border-radius: 2rem;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.05);
        display: inline-flex;
        list-style: none;
    }
    
    .pagination-premium .page-item {
        margin: 0;
    }
    
    .pagination-premium .page-link {
        border: none;
        background: transparent;
        color: #475569;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 1.5rem !important;
        font-size: 0.9rem;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }
    
    .pagination-premium .page-link:hover {
        background: rgba(15, 23, 42, 0.06);
        color: #0f172a;
        transform: translateY(-1px);
    }
    
    .pagination-premium .page-item.active .page-link {
        background: linear-gradient(135deg, #00A6EB, #00BA83);
        color: #ffffff;
        box-shadow: 0 4px 15px -3px rgba(0, 166, 235, 0.3);
    }
    
    .pagination-premium .page-item.disabled .page-link {
        color: #94a3b8;
        background: transparent;
        opacity: 0.5;
        cursor: not-allowed;
    }

    .pagination-premium .page-link-prev,
    .pagination-premium .page-link-next {
        border: 1.5px solid rgba(226, 232, 240, 0.6);
        background: #ffffff;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

    .pagination-premium .page-link-prev:hover,
    .pagination-premium .page-link-next:hover {
        background: #0f172a;
        color: #ffffff !important;
        border-color: #0f172a;
    }
</style>

<section class="bg-wp-primary text-white py-5 mb-4">
    <div class="container">
        <div class="row align-items-center mb-5">
            <div class="col-lg-7">
                <h1 class="display-5 fw-black mb-3">¿Cambiamos de plan?</h1>
                <p class="lead opacity-75">Selecciona tu vibra de hoy para ajustar las recomendaciones.</p>
            </div>
            <div class="col-lg-5 text-lg-end mt-3 mt-lg-0">
                <a href="/Home/Explorar" class="btn btn-outline-light rounded-pill px-4 @(planActual == "todos" ? "active" : "")">Ver Todos</a>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            @{
                var planes = new[] {
                    new { Id = "solo", Label = "Plan solo", Sub = "Productividad", Icon = "user", ActiveColor = "#0d6efd" },
                    new { Id = "pareja", Label = "Plan pareja", Sub = "Citas & Relax", Icon = "heart", ActiveColor = "#dc3545" },
                    new { Id = "amigos", Label = "Plan amigos", Sub = "Diversión", Icon = "users", ActiveColor = "#ffc107" }
                };
            }

            @foreach (var p in planes)
            {
                var isActive = planActual == p.Id;
                <div class="col-md-4">
                    <a href="/Home/Explorar?plan=@p.Id" class="text-decoration-none">
                        <div class="card plan-card border-0 p-4 h-100 shadow-lg @(isActive ? "bg-white scale-up" : "bg-white bg-opacity-10 text-white")"
                             style="transition: all 0.3s ease; border-radius: 1.5rem;">
                            <div class="d-flex align-items-center">
                                <!-- Contenedor del Icono -->
                                <div class="rounded-3 d-flex align-items-center justify-content-center" 
                                     style="width: 54px; height: 54px; flex-shrink: 0; 
                                            background-color: @(isActive ? p.ActiveColor : "rgba(255,255,255,0.2)");">
                                    <i data-lucide="@p.Icon" class="text-white" style="width: 24px; height: 24px;"></i>
                                </div>
                                
                                <!-- Texto -->
                                <div class="ms-3 flex-grow-1">
                                    <h6 class="mb-0 fw-bold @(isActive ? "text-dark" : "text-white")">@p.Label</h6>
                                    <small class="@(isActive ? "text-muted" : "text-white opacity-75")">@p.Sub</small>
                                </div>

                                <!-- Checkmark si está activo -->
                                @if(isActive) { 
                                    <i data-lucide="check-circle-2" style="color: @p.ActiveColor; width: 22px; height: 22px; stroke-width: 2.5px;"></i> 
                                }
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section class="py-4">
    <div class="container">
    
        <div class="row mb-4">
            <div class="col-lg-12">
                <form method="get" action="/Home/Explorar" class="bg-white p-3 rounded-4 shadow-sm border d-flex flex-wrap gap-3 align-items-center">
                    
                    <input type="hidden" name="plan" value="@planActual" />

                    <div class="flex-grow-1 position-relative">
                        <i data-lucide="search" class="position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="width: 18px; height: 18px;"></i>
                        <input type="text" name="searchTerm" value="@ViewData["SearchTerm"]" class="form-control border-0 bg-light rounded-pill ps-5 py-2" placeholder="Buscar por nombre (Ej: Starbucks) o categoría...">
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-wp rounded-pill px-4 text-white d-inline-flex align-items-center gap-2" style="background: linear-gradient(135deg, #00A6EB, #00BA83); border: none;"><i data-lucide="search" style="width: 16px; height: 16px;"></i>Buscar</button>
                        
                        <select name="sortBy" class="form-select border border-secondary bg-light rounded-pill px-4" style="width: auto;" onchange="this.form.submit()">
                            <option value="">✨ Recomendados</option>
                            <option value="calificacion" selected="@(ViewData["SortBy"]?.ToString() == "calificacion" ? "selected" : null)">⭐ Mejor calificados</option>
                            <option value="cercanos" selected="@(ViewData["SortBy"]?.ToString() == "cercanos" ? "selected" : null)">📍 Más cercanos</option>
                            <option value="baratos" selected="@(ViewData["SortBy"]?.ToString() == "baratos" ? "selected" : null)">💸 Más baratos</option>
                        </select>
                    </div>
                </form>
            </div>
        </div>

        @* ==========================================================
           SECCIÓN: VISTOS RECIENTEMENTE (Sesiones + Redis Cloud)
           Solo aparece si el usuario ya visitó algún punto de interés.
           Los datos vienen de la sesión privada de ESTE usuario,
           que se almacena físicamente en Redis Cloud.
           ========================================================== *@
        @{
            var vistosRecientes = ViewBag.VistosRecientes as List<WebbyPoints.Models.PuntoInteres>;
        }

        @if (vistosRecientes != null && vistosRecientes.Count > 0)
        {
            <div class="vistos-recientes-section rounded-4 p-4 mb-5">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <div class="vistos-icon-wrapper">
                        <i data-lucide="history" style="width: 20px; height: 20px;"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0">Vistos recientemente</h5>
                        <p class="text-muted small mb-0">Lugares que exploraste en esta sesión</p>
                    </div>

                </div>

                <div class="row g-3">
                    @foreach (var punto in vistosRecientes)
                    {
                        <div class="col-12 col-md-6 col-lg-4">
                            <a href="/Home/Detalle/@punto.Id" class="text-decoration-none">
                                <div class="card visto-card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                                    <div class="row g-0 h-100">
                                        <div class="col-12 d-flex align-items-center">
                                            <div class="card-body py-3 px-3">
                                                <h6 class="fw-bold mb-1 text-dark">@punto.Nombre</h6>
                                                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill small mb-2" style="font-size: 0.7rem;">
                                                    @punto.Categoria
                                                </span>
                                                <div class="d-flex align-items-center gap-3 text-muted small" style="font-size: 0.8rem;">
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i data-lucide="star" class="text-warning fill-warning" style="width: 14px; height: 14px; stroke: #f59e0b;"></i> @punto.Calificacion.ToString("0.0")
                                                    </span>
                                                    <span class="d-flex align-items-center gap-1">
                                                        <i data-lucide="dollar-sign" class="text-primary" style="width: 14px; height: 14px;"></i> @punto.PrecioRango
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
            <div class="d-flex align-items-center gap-2">
                <h3 class="fw-bold mb-0">Recomendaciones para ti</h3>
                @if (ViewData["IA_Enabled"]?.ToString() == "True")
                {
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill py-2 px-3 d-inline-flex align-items-center gap-1.5 shadow-sm" style="background: linear-gradient(135deg, #dbeafe, #eff6ff); animation: pulse 2s infinite;">
                        <i data-lucide="sparkles" class="text-primary fill-primary-subtle" style="width: 16px; height: 16px;"></i>
                        <strong>Curado por IA (ML.NET)</strong>
                    </span>
                }
                else
                {
                    <span class="badge bg-@(config.Color)-subtle text-@(config.Color) rounded-pill py-2 px-3 d-inline-flex align-items-center gap-1">
                        <i data-lucide="@config.Icon" style="width: 16px; height: 16px;"></i>@config.Label
                    </span>
                }
            </div>
            
            @if (ViewData["IA_Enabled"]?.ToString() == "True")
            {
                <div class="text-muted small d-inline-flex align-items-center gap-2 bg-white border py-1.5 px-3 rounded-pill shadow-sm">
                    <i data-lucide="graduation-cap" class="text-primary" style="width: 16px; height: 16px;"></i>
                    <span>Optimizado para tu carrera: <strong>@ViewData["IA_Carrera"]</strong></span>
                </div>
            }
        </div>

        <div id="recommendations-anchor" style="scroll-margin-top: 100px;"></div>
        <div id="places-container" class="position-relative" style="min-height: 300px;">
            <partial name="_LugaresList" />
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Interceptar clicks de la paginación premium para cargarlos mediante AJAX
        document.addEventListener("click", function (e) {
            const link = e.target.closest(".pagination-premium a");
            if (link) {
                e.preventDefault();
                const url = link.getAttribute("href");
                if (url) {
                    cargarPaginaAjax(url);
                }
            }
        });

        function cargarPaginaAjax(url) {
            const container = document.getElementById("places-container");
            const anchor = document.getElementById("recommendations-anchor");
            if (!container) return;

            // Transición suave de carga
            container.style.opacity = "0.45";
            container.style.transition = "opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1)";

            fetch(url, {
                headers: {
                    "X-Requested-With": "XMLHttpRequest"
                }
            })
            .then(response => {
                if (!response.ok) throw new Error("Fallo en la respuesta de red");
                return response.text();
            })
            .then(html => {
                container.innerHTML = html;
                container.style.opacity = "1";

                // Re-inicializar los iconos Lucide en el contenido inyectado
                if (window.lucide) {
                    window.lucide.createIcons();
                }

                // Hacer un scroll suave al inicio de las recomendaciones para mejorar la navegación
                if (anchor) {
                    anchor.scrollIntoView({ behavior: "smooth", block: "start" });
                }

                // Actualizar la barra de direcciones del navegador en tiempo real
                window.history.pushState({ path: url }, "", url);
            })
            .catch(err => {
                console.error("[AJAX Error] No se pudo paginar:", err);
                container.style.opacity = "1";
            });
        }
    });
</script>
    </div>
</section>