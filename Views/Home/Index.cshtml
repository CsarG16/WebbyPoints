@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<section class="hero-fullscreen position-relative" id="heroSection">

    <!-- CARRUSEL DE FONDO -->
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
        
        <div class="carousel-inner">

            <div class="carousel-item active">
                <img src="/images/fondoIndex.png" class="hero-bg-image" loading="eager" alt="Fondo WebbyPoints">
            </div>

            <div class="carousel-item">
                <img src="/images/fondo2.jpeg" class="hero-bg-image" loading="lazy" alt="Fondo Explorar">
            </div>

            <div class="carousel-item">
                <img src="/images/fondo3.jpg" class="hero-bg-image" loading="lazy" alt="Fondo Comunidad">
            </div>

        </div>

    </div>

    <!-- OVERLAY -->
    <div class="hero-overlay"></div>

    <!-- CONTENIDO -->
    <div class="container position-relative z-3 hero-content-wrapper">
        <div class="row w-100">
            <div class="col-lg-8 col-xl-7 text-start">

                <span class="d-block hero-subtitle mb-2">ENCUENTRA TU</span>
                <h1 class="hero-title mb-4">
                    LUGAR FAVORITO
                </h1>

                <p class="hero-description mb-5">
                    La plataforma diseñada por y para estudiantes. Encuentra
                    cafés, restaurantes, bares y espacios únicos cerca de tu
                    universidad, según tu estado de ánimo.
                </p>

                <div class="d-flex flex-wrap justify-content-start gap-3 mb-4">
                    @if (Context.Session.GetInt32("UsuarioId") == null)
                    {
                        <!-- PRUEBA DIRECTA -->
                        <a href="/Account/RegistroPaso1" class="btn btn-hero-primary">
                            <i class="bi bi-rocket-takeoff me-2"></i>¡Unirme ahora!
                        </a>

                        <a href="/Account/Login" class="btn btn-hero-outline">
                            Ya tengo cuenta
                        </a>
                    }
                    else
                    {
                        <a href="/Home/Explorar?plan=solo" class="btn btn-hero-primary">
                            <i class="bi bi-compass me-2"></i>Empezar a explorar
                        </a>

                        <a href="/Home/Explorar" class="btn btn-hero-outline">
                            Ver planes
                        </a>
                    }
                </div>

            </div>
        </div>
    </div>

</section>