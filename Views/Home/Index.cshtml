@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<section class="hero-fullscreen position-relative" id="heroSection">

    <!-- CARRUSEL DE FONDO -->
    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
        
        <div class="carousel-inner">

            <div class="carousel-item active">
                <div class="hero-bg-image" style="background-image: url('/images/fondo1.jpg');"></div>
            </div>

            <div class="carousel-item">
                <div class="hero-bg-image" style="background-image: url('/images/fondoIndex.png');"></div>
            </div>

            <div class="carousel-item">
                <div class="hero-bg-image" style="background-image: url('/images/fondo2.jpg');"></div>
            </div>

            <div class="carousel-item">
                <div class="hero-bg-image" style="background-image: url('/images/imagen3.jpg');"></div>
            </div>

        </div>

    </div>

    <!-- OVERLAY -->
    <div class="hero-overlay"></div>

    <!-- CONTENIDO -->
    <div class="container position-relative z-3 d-flex align-items-end pb-5 mb-4" style="height: 100vh;">
        <div class="row">
            <div class="col-lg-7 col-xl-6">

                <span class="badge hero-badge mb-3">
                    <i class="bi bi-geo-alt-fill me-1"></i>Explora tu campus
                </span>

                <p class="hero-subtitle mb-1">DESCUBRE TU</p>

                <h1 class="hero-title mb-3">
                    LUGAR<br/>FAVORITO
                </h1>

                <p class="hero-description mb-4">
                    La plataforma diseñada por y para estudiantes. Encuentra
                    cafés, restaurantes, bares y espacios únicos cerca de tu
                    universidad, según tu estado de ánimo.
                </p>

                <div class="d-flex flex-wrap gap-3 mb-4">
                    @if (Context.Session.GetInt32("UsuarioId") == null)
                    {
                        <a href="/Account/RegistroPaso1" class="btn btn-hero-primary">
                            <i class="bi bi-rocket-takeoff me-2"></i>¡Unirme ahora!
                        </a>
                        <a href="/Account/Login" class="btn btn-hero-outline">
                            Ya tengo cuenta
                        </a>
                    }
                    else
                    {
                        <a href="/Home/Explorar?plan=solo" class="btn btn-hero-primary">
                            <i class="bi bi-compass me-2"></i>Empezar a explorar
                        </a>
                        <a href="#planesSection" class="btn btn-hero-outline">
                            Ver planes
                        </a>
                    }
                </div>

            </div>
        </div>
    </div>

</section>