@{
    ViewData["Title"] = "Inicio";
}

<!-- Hero Section -->
<section class="bg-wp-primary text-white py-5">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <span class="badge rounded-pill bg-white bg-opacity-10 border border-white border-opacity-25 mb-3 py-2 px-3 text-uppercase small">
                    <i class="bi bi-geo-alt me-1"></i>Explora tu campus
                </span>
                <h1 class="display-3 fw-black mb-4">
                    Webby<br/>Points
                </h1>
                <p class="lead opacity-75 mb-4" style="max-width: 480px;">
                    La plataforma diseñada por y para estudiantes. Encuentra el lugar perfecto según tu estado de ánimo.
                </p>

                <div class="d-flex flex-column flex-sm-row gap-3 mb-5">
                    @if (Context.Session.GetInt32("UsuarioId") == null)
                    {
                        <a href="/Account/RegistroPaso1" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary shadow-sm">
                            <i class="bi bi-rocket-takeoff me-2"></i>¡Unirme ahora!
                        </a>
                        <a href="/Account/Login" class="btn btn-outline-light btn-lg rounded-pill px-4 fw-medium">
                            Ya tengo cuenta
                        </a>
                    }
                    else
                    {
                        <a href="/Home/Explorar?plan=solo" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary shadow-sm">
                            <i class="bi bi-compass me-2"></i>Empezar a explorar
                        </a>
                    }
                </div>

                <div class="d-flex gap-4">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-white bg-opacity-10 p-2 rounded-3"><i class="bi bi-geo-alt"></i></div>
                        <span class="small fw-medium">Cerca de tu sede USMP</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-white bg-opacity-10 p-2 rounded-3"><i class="bi bi-star"></i></div>
                        <span class="small fw-medium">Reseñas reales</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="bg-white bg-opacity-10 rounded-4 p-4 border border-white border-opacity-10">
                    <h5 class="fw-bold mb-1 text-white"><i class="bi bi-lightning-charge me-2"></i>Dato rápido</h5>
                    <p class="small opacity-75 mb-0">Cada reseña que publiques te da puntos para subir de rango. ¡Comienza como Explorador y conviértete en Leyenda!</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Planes Section -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-dark mb-2">¿Qué quieres hacer hoy?</h2>
            <p class="text-muted">Selecciona el tipo de plan para recomendarte lo mejor.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Plan Solo -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=solo" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary-subtle text-primary" style="width: 56px; height: 56px;">
                                <i class="bi bi-person-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan solo</h5>
                                <small class="text-muted">Productividad y relax</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Cafés tranquilos, bibliotecas, espacios de estudio y más para tu tiempo a solas.</p>
                    </div>
                </a>
            </div>

            <!-- Plan Pareja -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=pareja" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-danger-subtle text-danger" style="width: 56px; height: 56px;">
                                <i class="bi bi-heart-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan pareja</h5>
                                <small class="text-muted">Momentos especiales</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Restaurantes románticos, parques y lugares ideales para una cita perfecta.</p>
                    </div>
                </a>
            </div>

            <!-- Plan Amigos -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=amigos" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-warning-subtle text-warning" style="width: 56px; height: 56px;">
                                <i class="bi bi-people-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan amigos</h5>
                                <small class="text-muted">Diversión garantizada</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Bares, gaming, restaurantes grupales y todo lo que necesitas para pasarla bien.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>