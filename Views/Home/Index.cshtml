@{
    ViewData["Title"] = "Inicio";
}

<div class="container-fluid p-0 overflow-hidden">
    <div class="row g-0 min-vh-100">
        <!-- Sidebar Izquierda -->
        <div class="col-md-5 d-flex flex-column justify-content-center p-5 text-white shadow-lg z-1" 
             style="background-color: #1A4BDE; border-top-right-radius: 4rem; border-bottom-right-radius: 4rem;">
            <div class="mx-auto" style="max-width: 400px;">
                <span class="badge rounded-pill mb-4 py-2 px-3 tracking-widest text-uppercase" 
                      style="background-color: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                    Explora tu campus
                </span>
                <h1 class="display-1 fw-black mb-4">
                    Webby<br/>Points
                </h1>
                <p class="lead mb-5 opacity-75">
                    La plataforma diseñada por y para estudiantes. Encuentra el lugar perfecto según tu estado de ánimo.
                </p>
                
                <div class="vstack gap-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-10 p-2 rounded-3"><i class="bi bi-geo-alt"></i></div>
                        <span class="small fw-medium">Cerca de tu sede UPC</span>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-white bg-opacity-10 p-2 rounded-3"><i class="bi bi-star"></i></div>
                        <span class="small fw-medium">Reseñas reales</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contenido Derecha -->
        <div class="col-md-7 d-flex flex-column justify-content-center align-items-center p-4 p-md-5 bg-light">
            <div class="w-100" style="max-width: 450px;">
                <h2 class="fw-bold text-dark mb-2">¿Qué quieres hacer hoy?</h2>
                <p class="text-muted mb-5">Selecciona el tipo de plan para recomendarte lo mejor.</p>

                <div class="vstack gap-4">
                    <!-- Plan Solo -->
                    <a href="/Home/Explorar?plan=solo" 
                       class="text-decoration-none group d-flex align-items-center p-4 bg-white rounded-5 border shadow-sm transition-all hover-shadow">
                        <div class="rounded-4 d-flex align-items-center justify-content-center bg-primary-subtle text-primary" 
                             style="width: 64px; height: 64px;">
                            <i class="bi bi-person-fill fs-2"></i>
                        </div>
                        <div class="ms-4 flex-grow-1">
                            <h4 class="mb-1 fw-bold text-dark">Plan solo</h4>
                            <p class="mb-0 text-muted small">Productividad y relax</p>
                        </div>
                        <i class="bi bi-arrow-right text-secondary fs-4"></i>
                    </a>

                    <!-- Plan Pareja -->
                    <a href="/Home/Explorar?plan=pareja" 
                       class="text-decoration-none group d-flex align-items-center p-4 bg-white rounded-5 border shadow-sm transition-all hover-shadow">
                        <div class="rounded-4 d-flex align-items-center justify-content-center bg-danger-subtle text-danger" 
                             style="width: 64px; height: 64px;">
                            <i class="bi bi-heart-fill fs-2"></i>
                        </div>
                        <div class="ms-4 flex-grow-1">
                            <h4 class="mb-1 fw-bold text-dark">Plan pareja</h4>
                            <p class="mb-0 text-muted small">Momentos especiales</p>
                        </div>
                        <i class="bi bi-arrow-right text-secondary fs-4"></i>
                    </a>

                    <!-- Plan Amigos -->
                    <a href="/Home/Explorar?plan=amigos" 
                       class="text-decoration-none group d-flex align-items-center p-4 bg-white rounded-5 border shadow-sm transition-all hover-shadow">
                        <div class="rounded-4 d-flex align-items-center justify-content-center bg-warning-subtle text-warning" 
                             style="width: 64px; height: 64px;">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                        <div class="ms-4 flex-grow-1">
                            <h4 class="mb-1 fw-bold text-dark">Plan amigos</h4>
                            <p class="mb-0 text-muted small">Diversión garantizada</p>
                        </div>
                        <i class="bi bi-arrow-right text-secondary fs-4"></i>
                    </a>
                </div>

                <footer class="mt-5 text-center text-muted small">
                    &copy; 2026 Webby Points · Facultad de Ingeniería UPC
                </footer>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
    .fw-black { font-weight: 900; }
    .rounded-5 { border-radius: 2rem !important; }
</style>
>
</div>