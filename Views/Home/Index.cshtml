@{
    ViewData["Title"] = "Inicio";
    Layout = "_Layout";
}

<!-- ============================================
     HERO SECTION - Fullscreen con imagen de fondo
     ============================================ -->
<section class="hero-fullscreen position-relative d-flex align-items-end" id="heroSection">
    <!-- Imagen de fondo -->
    <div class="hero-bg-image"></div>
    <!-- Overlay oscuro degradado -->
    <div class="hero-overlay"></div>

    <!-- Contenido del Hero -->
    <div class="container position-relative z-3 pb-5 mb-4">
        <div class="row">
            <div class="col-lg-7 col-xl-6">
                <!-- Badge superior -->
                <span class="badge hero-badge mb-3">
                    <i class="bi bi-geo-alt-fill me-1"></i>Explora tu campus
                </span>

                <!-- Título principal estilo "INTO THE WILD" -->
                <p class="hero-subtitle mb-1">DESCUBRE TU</p>
                <h1 class="hero-title mb-3">
                    LUGAR<br/>FAVORITO
                </h1>

                <!-- Descripción -->
                <p class="hero-description mb-4">
                    La plataforma diseñada por y para estudiantes. Encuentra
                    cafés, restaurantes, bares y espacios únicos cerca de tu
                    universidad, según tu estado de ánimo.
                </p>

                <!-- Botones CTA -->
                <div class="d-flex flex-wrap gap-3 mb-4">
                    @if (Context.Session.GetInt32("UsuarioId") == null)
                    {
                        <a href="/Account/RegistroPaso1" class="btn btn-hero-primary">
                            <i class="bi bi-rocket-takeoff me-2"></i>¡Unirme ahora!
                        </a>
                        <a href="/Account/Login" class="btn btn-hero-outline">
                            Ya tengo cuenta
                        </a>
                    }
                    else
                    {
                        <a href="/Home/Explorar?plan=solo" class="btn btn-hero-primary">
                            <i class="bi bi-compass me-2"></i>Empezar a explorar
                        </a>
                        <a href="#planesSection" class="btn btn-hero-outline">
                            Ver planes
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Indicadores estilo carousel -->
        <div class="hero-indicators d-flex align-items-center gap-3 mt-3">
            <div class="d-flex gap-2 align-items-center">
                <span class="hero-dot active"></span>
                <span class="hero-dot"></span>
                <span class="hero-dot"></span>
            </div>
            <div class="hero-progress-bar">
                <div class="hero-progress-fill"></div>
            </div>
        </div>
    </div>

    <!-- Dato rápido flotante (esquina inferior derecha) -->
    <div class="hero-floating-card d-none d-lg-block">
        <div class="d-flex align-items-center gap-2 mb-2">
            <i class="bi bi-lightning-charge-fill text-warning"></i>
            <span class="fw-semibold small">Dato rápido</span>
        </div>
        <p class="mb-0 small opacity-75">
            Cada reseña te da puntos para subir de rango.<br/>
            ¡Sé un <strong>Explorador</strong> y conviértete en <strong>Leyenda</strong>!
        </p>
    </div>
</section>

<!-- ============================================
     PLANES SECTION - Cards de selección de plan
     ============================================ -->
<section class="py-5" id="planesSection">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3 fw-semibold small text-uppercase">
                <i class="bi bi-stars me-1"></i>Elige tu aventura
            </span>
            <h2 class="fw-bold text-dark mb-2 display-6">¿Qué quieres hacer hoy?</h2>
            <p class="text-muted mx-auto" style="max-width: 500px;">
                Selecciona el tipo de plan y te recomendaremos los mejores lugares cerca de ti.
            </p>
        </div>

        <div class="row g-4 justify-content-center">
            <!-- Plan Solo -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=solo" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-primary-subtle text-primary" style="width: 56px; height: 56px;">
                                <i class="bi bi-person-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan solo</h5>
                                <small class="text-muted">Productividad y relax</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Cafés tranquilos, bibliotecas, espacios de estudio y más para tu tiempo a solas.</p>
                    </div>
                </a>
            </div>

            <!-- Plan Pareja -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=pareja" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-danger-subtle text-danger" style="width: 56px; height: 56px;">
                                <i class="bi bi-heart-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan pareja</h5>
                                <small class="text-muted">Momentos especiales</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Restaurantes románticos, parques y lugares ideales para una cita perfecta.</p>
                    </div>
                </a>
            </div>

            <!-- Plan Amigos -->
            <div class="col-md-4">
                <a href="/Home/Explorar?plan=amigos" class="text-decoration-none">
                    <div class="card plan-card bg-white p-4 h-100 shadow-sm">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-3 d-flex align-items-center justify-content-center bg-warning-subtle text-warning" style="width: 56px; height: 56px;">
                                <i class="bi bi-people-fill fs-3"></i>
                            </div>
                            <div class="ms-3 flex-grow-1">
                                <h5 class="mb-0 fw-bold text-dark">Plan amigos</h5>
                                <small class="text-muted">Diversión garantizada</small>
                            </div>
                            <i class="bi bi-arrow-right text-secondary fs-5"></i>
                        </div>
                        <p class="text-muted small mb-0">Bares, gaming, restaurantes grupales y todo lo que necesitas para pasarla bien.</p>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>