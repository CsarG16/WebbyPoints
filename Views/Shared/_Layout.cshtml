<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Webby Points</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg wp-navbar py-2 @(ViewData["Title"]?.ToString() != "Inicio" ? "scrolled" : "")">
        <div class="container">
            <a class="navbar-brand fw-black fs-4" href="/">
                <span class="text-wp-primary">Webby</span><span class="text-dark">Points</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/Home/Explorar">
                            <i class="bi bi-compass me-1"></i>Explorar
                        </a>
                    </li>

                    @{
                        var usuarioId = Context.Session.GetInt32("UsuarioId");
                        var nombreUsuario = Context.Session.GetString("UsuarioNombre");
                        var puntosUsuario = Context.Session.GetInt32("UsuarioPuntos") ?? 0;
                    }

                    @if (usuarioId != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-medium" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>Hola, @nombreUsuario
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow rounded-3">
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-person me-2"></i>Mi perfil</a></li>
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-star me-2"></i>Mis reseñas</a></li>
                                @{
                                    var esAdmin = Context.Session.GetInt32("EsAdmin") ?? 0;
                                }
                                @if (esAdmin == 1)
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-primary fw-semibold" href="/Admin"><i class="bi bi-shield-lock me-2"></i>Panel Admin</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-left me-2"></i>Cerrar sesión</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-medium" href="/Account/Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Entrar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-wp btn-sm px-3" href="/Account/RegistroPaso1">
                                Registrarse
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>