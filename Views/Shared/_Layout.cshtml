<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Webby Points</title>

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Chat IA CSS -->
    <link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg wp-navbar py-2 @(ViewData["Title"]?.ToString() != "Inicio" ? "scrolled" : "")">
        <div class="container">
            <a class="navbar-brand fw-black fs-4" href="/">
                <span class="text-wp-primary">Webby</span><span class="text-dark">Points</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <a class="nav-link fw-medium d-flex align-items-center gap-1" href="/Home/Explorar">
                            <i data-lucide="compass"></i>Explorar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium d-flex align-items-center gap-1" href="/Recompensas">
                            <i data-lucide="gift"></i>Tienda
                        </a>
                    </li>

                    @{
                        var usuarioId = Context.Session.GetInt32("UsuarioId");
                        var nombreUsuario = Context.Session.GetString("UsuarioNombre");
                        var puntosUsuario = Context.Session.GetInt32("UsuarioPuntos") ?? 0;
                    }

                    @if (usuarioId != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-medium d-flex align-items-center gap-1" href="#" role="button" data-bs-toggle="dropdown">
                                <i data-lucide="user"></i>Hola, @nombreUsuario
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow rounded-3">
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" href="/Account/Perfil"><i data-lucide="user" class="text-muted"></i>Mi perfil</a></li>
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" href="/Recompensas/MisCanjes"><i data-lucide="ticket" class="text-muted"></i>Mis canjes</a></li>
                                <li><a class="dropdown-item py-2 d-flex align-items-center gap-2" href="/Recompensas"><i data-lucide="gift" class="text-muted"></i>Tienda</a></li>
                                @{
                                    var esAdmin = Context.Session.GetInt32("EsAdmin") ?? 0;
                                }
                                @if (esAdmin == 1)
                                {
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item py-2 text-primary fw-semibold d-flex align-items-center gap-2" href="/Admin"><i data-lucide="shield-alert"></i>Panel Admin</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger d-flex align-items-center gap-2" href="/Account/Logout"><i data-lucide="log-out"></i>Cerrar sesión</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link fw-medium d-flex align-items-center gap-1" href="/Account/Login">
                                <i data-lucide="log-in"></i>Entrar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-wp btn-sm px-3 d-flex align-items-center" href="/Account/RegistroPaso1">
                                Registrarse
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main">
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            lucide.createIcons();
        });
    </script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Chat Widget de IA Flotante -->
    <button class="chat-widget-toggle" id="chatWidgetToggle" title="Hablar con Guía Universitario IA">
        <i data-lucide="message-square"></i>
    </button>

    <div class="chat-widget-container" id="chatWidgetContainer">
        <div class="chat-widget-header">
            <div class="chat-widget-header-info">
                <div class="chat-widget-avatar">
                    <i data-lucide="bot"></i>
                </div>
                <div>
                    <h5 class="chat-widget-title">Guía Universitario</h5>
                    <div class="chat-widget-status">
                        <span class="chat-widget-status-dot"></span>
                        <span>En línea (Ollama)</span>
                    </div>
                </div>
            </div>
            <div class="chat-widget-header-actions">
                <button class="chat-widget-btn-action" id="chatWidgetReset" title="Reiniciar conversación">
                    <i data-lucide="rotate-ccw" style="width:16px;height:16px;"></i>
                </button>
                <button class="chat-widget-btn-action" id="chatWidgetClose" title="Cerrar chat">
                    <i data-lucide="x" style="width:18px;height:18px;"></i>
                </button>
            </div>
        </div>
        
        <div class="chat-widget-messages" id="chatWidgetMessages">
            <!-- Mensajes cargados dinámicamente -->
        </div>

        <div class="chat-widget-suggestions">
            <button class="suggestion-chip" data-msg="¿Qué lugares hay para estudiar?">Estudiar 📚</button>
            <button class="suggestion-chip" data-msg="Recomiéndame algo para hacer con amigos que dé bastantes puntos.">Amigos 👥</button>
            <button class="suggestion-chip" data-msg="¿Qué recompensas puedo canjear con mis puntos?">Recompensas 🎁</button>
        </div>

        <div class="chat-widget-input-area">
            <form class="chat-widget-form" id="chatWidgetForm" autocomplete="off">
                <input type="text" class="chat-widget-input" id="chatWidgetInput" placeholder="Pregúntame algo..." required />
                <button type="submit" class="chat-widget-send-btn">
                    <i data-lucide="send"></i>
                </button>
            </form>
        </div>
    </div>

    <script src="~/js/chat.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>