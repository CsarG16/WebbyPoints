@model List<WebbyPoints.Models.Recompensa>
@{
    ViewData["Title"] = "Tienda de Recompensas";
    var puntos = (int)ViewBag.PuntosUsuario;
    var logueado = (bool)ViewBag.UsuarioLogueado;
    var categoriaActual = ViewBag.CategoriaActual?.ToString() ?? "Todas";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
}

@section Scripts {
<script>
    function canjearRecompensa(id, nombre, costo) {
        const modal = document.getElementById('canjeModal');
        document.getElementById('modalNombre').textContent = nombre;
        document.getElementById('modalCosto').textContent = costo;
        document.getElementById('modalRecompensaId').value = id;
        document.getElementById('modalResultado').classList.add('d-none');
        document.getElementById('modalConfirmacion').classList.remove('d-none');
        document.getElementById('btnConfirmar').classList.remove('d-none');
        new bootstrap.Modal(modal).show();
    }

    async function confirmarCanje() {
        const id = document.getElementById('modalRecompensaId').value;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const btn = document.getElementById('btnConfirmar');
        
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Procesando...';

        try {
            const resp = await fetch('/Recompensas/Canjear', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `recompensaId=${id}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });
            const data = await resp.json();

            document.getElementById('modalConfirmacion').classList.add('d-none');
            btn.classList.add('d-none');
            const resultado = document.getElementById('modalResultado');
            resultado.classList.remove('d-none');

            if (data.success) {
                resultado.innerHTML = `
                    <div class="text-center py-3">
                        <div class="canje-success-icon mb-3 d-flex align-items-center justify-content-center bg-success bg-opacity-10 rounded-circle mx-auto" style="width: 72px; height: 72px;">
                            <i data-lucide="check-circle-2" class="text-success" style="width: 44px; height: 44px; stroke-width: 2.5px;"></i>
                        </div>
                        <h4 class="fw-bold text-success mb-2">¡Canje Exitoso!</h4>
                        <p class="text-muted mb-3">Presenta este código en el establecimiento:</p>
                        <div class="voucher-code-display mx-auto mb-3">
                            <span class="fw-black">${data.codigoVoucher}</span>
                        </div>
                        <p class="small text-muted">Puntos restantes: <strong>${data.puntosRestantes}</strong></p>
                    </div>`;
                // Actualizar puntos en la página
                document.getElementById('puntosHeader').textContent = data.puntosRestantes;
                // Renderizar iconos de Lucide dinámicos
                lucide.createIcons();
                // Recargar después de cerrar
                document.getElementById('canjeModal').addEventListener('hidden.bs.modal', () => location.reload(), { once: true });
            } else {
                resultado.innerHTML = `
                    <div class="text-center py-3">
                        <i data-lucide="alert-triangle" class="text-warning mx-auto" style="width: 48px; height: 48px;"></i>
                        <h5 class="fw-bold mt-3">No se pudo canjear</h5>
                        <p class="text-muted">${data.error}</p>
                    </div>`;
                lucide.createIcons();
            }
        } catch (e) {
            btn.disabled = false;
            btn.innerHTML = 'Confirmar Canje';
            alert('Error de conexión. Intenta de nuevo.');
        }
    }
</script>
}

<!-- ANTI-FORGERY TOKEN GLOBAL -->
<form id="afForm" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<!-- ======================================================
     HEADER: Puntos del usuario + título
     ====================================================== -->
<section class="tienda-hero">
    <div class="container">
        <div class="row align-items-center py-5">
            <div class="col-lg-7">
                <span class="badge-glow mb-3 d-inline-flex align-items-center gap-1.5">
                    <i data-lucide="gift"></i> TIENDA DE RECOMPENSAS
                </span>
                <h1 class="display-4 fw-black text-white mb-3">
                    Canjea tus puntos<br>por premios reales
                </h1>
                <p class="text-white text-opacity-75 fs-5 mb-0">
                    Cada acción cuenta. Participa en eventos, deja reseñas y canjea
                    tus puntos por experiencias, descuentos y merchandising exclusivo.
                </p>
            </div>
            <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
                @if (logueado)
                {
                    <div class="puntos-card-hero">
                        <div class="puntos-card-label">Tus puntos disponibles</div>
                        <div class="puntos-card-valor" id="puntosHeader">@puntos</div>
                        <div class="puntos-card-label mt-2">
                            <a href="/Account/Perfil" class="text-white text-decoration-none opacity-75 d-inline-flex align-items-center gap-1">
                                <i data-lucide="user" style="width: 14px; height: 14px;"></i>Ver mi perfil →
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="puntos-card-hero">
                        <div class="puntos-card-label mb-2">¿Quieres canjear premios?</div>
                        <a href="/Account/Login" class="btn btn-light btn-lg rounded-pill fw-bold px-4 d-inline-flex align-items-center gap-2 mx-auto justify-content-center">
                            <i data-lucide="log-in" style="width: 20px; height: 20px;"></i>Inicia sesión
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ======================================================
     FILTROS POR CATEGORÍA
     ====================================================== -->
<section class="py-4 bg-white border-bottom sticky-top" style="z-index: 1020;">
    <div class="container">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="text-muted fw-medium me-2 d-inline-flex align-items-center gap-1"><i data-lucide="filter" style="width: 16px; height: 16px;"></i>Filtrar:</span>
            <a href="/Recompensas"
               class="btn btn-filter @(categoriaActual == "Todas" ? "active" : "")">
                Todas
            </a>
            @foreach (var cat in categorias)
            {
                var icono = cat switch {
                    "Descuento" => "tag",
                    "Merchandising" => "shopping-bag",
                    "Ocio" => "gamepad-2",
                    "Experiencia" => "sparkles",
                    "Cultura" => "palette",
                    _ => "gift"
                };
                <a href="/Recompensas?categoria=@cat"
                   class="btn btn-filter @(categoriaActual == cat ? "active" : "") d-inline-flex align-items-center gap-1.5">
                    <i data-lucide="@icono" style="width: 14px; height: 14px;"></i>@cat
                </a>
            }
        </div>
    </div>
</section>

<!-- ======================================================
     GRID DE RECOMPENSAS
     ====================================================== -->
<section class="py-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i data-lucide="inbox" class="text-muted opacity-40 mx-auto" style="width: 64px; height: 64px;"></i>
                <h4 class="fw-bold mt-3">No hay recompensas en esta categoría</h4>
                <p class="text-muted">Intenta con otra categoría o vuelve más tarde.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var r in Model)
                {
                    var puedeCanjar = logueado && puntos >= r.CostoPuntos && r.Stock != 0;
                    var agotado = r.Stock == 0;
                    <div class="col-sm-6 col-lg-4 col-xl-3">
                        <div class="reward-card h-100 @(agotado ? "agotado" : "")">
                            <!-- Imagen -->
                            <div class="reward-card-img">
                                <img src="@r.ImagenUrl" alt="@r.Nombre" loading="lazy" />
                                <span class="reward-cat-badge">
                                    @r.Categoria
                                </span>
                                @if (agotado)
                                {
                                    <div class="reward-agotado-overlay">
                                        <span>AGOTADO</span>
                                    </div>
                                }
                            </div>
                            <!-- Contenido -->
                            <div class="reward-card-body">
                                <h6 class="fw-bold mb-1">@r.Nombre</h6>
                                <p class="text-muted small mb-3 reward-desc">@r.Descripcion</p>

                                <div class="d-flex align-items-center justify-content-between mt-auto">
                                    <div class="reward-cost">
                                        <i data-lucide="star" class="text-warning fill-warning me-1" style="width: 14px; height: 14px; stroke: #f59e0b;"></i>
                                        <span class="fw-black">@r.CostoPuntos</span>
                                        <span class="text-muted small">pts</span>
                                    </div>

                                    @if (r.Stock > 0 && r.Stock <= 10)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning small d-inline-flex align-items-center gap-1" style="color: #b45309 !important;">
                                            <i data-lucide="flame" style="width: 12px; height: 12px;"></i>Quedan @r.Stock
                                        </span>
                                    }
                                </div>
                            </div>
                            <!-- Botón -->
                            <div class="reward-card-footer">
                                @if (!logueado)
                                {
                                    <a href="/Account/Login" class="btn btn-outline-primary w-100 rounded-pill btn-sm d-inline-flex align-items-center justify-content-center gap-1">
                                        <i data-lucide="log-in" style="width: 14px; height: 14px;"></i>Inicia sesión
                                    </a>
                                }
                                else if (agotado)
                                {
                                    <button class="btn btn-secondary w-100 rounded-pill btn-sm text-center" disabled>
                                        Agotado
                                    </button>
                                }
                                else if (puedeCanjar)
                                {
                                    <button class="btn btn-canjear w-100 rounded-pill btn-sm d-inline-flex align-items-center justify-content-center gap-1"
                                            onclick="canjearRecompensa(@r.Id, '@r.Nombre.Replace("'", "\\'")', @r.CostoPuntos)">
                                        <i data-lucide="gift" style="width: 14px; height: 14px;"></i>Canjear
                                    </button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary w-100 rounded-pill btn-sm d-inline-flex align-items-center justify-content-center gap-1" disabled>
                                        <i data-lucide="lock" style="width: 14px; height: 14px;"></i>Faltan @(r.CostoPuntos - puntos) pts
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<!-- ======================================================
     MODAL DE CONFIRMACIÓN DE CANJE
     ====================================================== -->
<div class="modal fade" id="canjeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
            <div class="modal-header border-0 bg-gradient-primary text-white py-4">
                <div>
                    <h5 class="modal-title fw-bold mb-1 d-flex align-items-center gap-2">
                        <i data-lucide="gift"></i>Confirmar Canje
                    </h5>
                    <small class="opacity-75">Esta acción descontará puntos de tu cuenta</small>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="modalRecompensaId" />

                <!-- Confirmación -->
                <div id="modalConfirmacion">
                    <div class="text-center mb-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px;">
                            <i data-lucide="star" class="text-primary fill-primary" style="width: 32px; height: 32px; stroke: #1A4BDE;"></i>
                        </div>
                    </div>
                    <p class="text-center mb-1">Estás a punto de canjear:</p>
                    <h5 class="text-center fw-bold mb-3" id="modalNombre"></h5>
                    <div class="bg-light rounded-3 p-3 text-center mb-3">
                        <span class="text-muted">Costo:</span>
                        <span class="fw-black text-primary fs-4 ms-2" id="modalCosto"></span>
                        <span class="text-muted">puntos</span>
                    </div>
                    <p class="text-muted text-center small d-flex align-items-center justify-content-center gap-1" style="font-size: 0.8rem;">
                        <i data-lucide="info" style="width: 14px; height: 14px;"></i>
                        Recibirás un código voucher único que podrás presentar en el establecimiento.
                    </p>
                </div>

                <!-- Resultado -->
                <div id="modalResultado" class="d-none"></div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 fw-bold d-inline-flex align-items-center gap-1.5" id="btnConfirmar" onclick="confirmarCanje()">
                    <i data-lucide="check-circle" style="width: 16px; height: 16px;"></i>Confirmar Canje
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .fill-warning {
        fill: currentColor;
    }
    .fill-primary {
        fill: currentColor;
    }
</style>
