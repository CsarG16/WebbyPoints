@model List<WebbyPoints.Models.Canje>
@{
    ViewData["Title"] = "Mis Canjes";
    var puntos = (int)ViewBag.PuntosUsuario;
}

<!-- HEADER -->
<section class="tienda-hero" style="min-height: auto;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <a href="/Recompensas" class="text-white text-decoration-none opacity-75 d-inline-block mb-3">
                    <i class="bi bi-arrow-left me-1"></i> Volver a la tienda
                </a>
                <h1 class="display-5 fw-black text-white mb-2">Mis Canjes</h1>
                <p class="text-white text-opacity-75 fs-6">
                    Aquí están todos tus vouchers. Presenta el código en el establecimiento para reclamar tu premio.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <div class="puntos-card-hero" style="display: inline-block;">
                    <div class="puntos-card-label">Puntos disponibles</div>
                    <div class="puntos-card-valor">@puntos</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-ticket-perforated text-muted" style="font-size: 4rem;"></i>
                <h4 class="fw-bold mt-3">Aún no tienes canjes</h4>
                <p class="text-muted mb-4">Visita la tienda y canjea tus puntos por premios increíbles.</p>
                <a href="/Recompensas" class="btn btn-primary rounded-pill px-4">
                    <i class="bi bi-gift me-2"></i>Ir a la Tienda
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var c in Model)
                {
                    var esDisponible = c.Estado == "Disponible";
                    <div class="col-md-6 col-lg-4">
                        <div class="voucher-card @(!esDisponible ? "usado" : "")">
                            <div class="voucher-card-header">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="voucher-icon-box">
                                        <i class="bi bi-ticket-perforated-fill"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0">@c.Recompensa?.Nombre</h6>
                                        <small class="text-muted">@c.FechaCanje.ToString("dd MMM yyyy, hh:mm tt")</small>
                                    </div>
                                </div>
                            </div>
                            <div class="voucher-card-body">
                                <div class="voucher-code-display @(!esDisponible ? "usado" : "")">
                                    <span class="fw-black">@c.CodigoVoucher</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="small text-muted">
                                        <i class="bi bi-star-fill text-warning me-1"></i>@c.PuntosGastados pts
                                    </span>
                                    <span class="badge @(esDisponible ? "bg-success" : "bg-secondary") bg-opacity-10 @(esDisponible ? "text-success" : "text-secondary") rounded-pill px-3">
                                        <i class="bi @(esDisponible ? "bi-check-circle" : "bi-x-circle") me-1"></i>
                                        @c.Estado
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
