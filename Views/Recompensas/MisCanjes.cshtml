@model List<WebbyPoints.Models.Canje>
@{
    ViewData["Title"] = "Mis Canjes";
    var puntos = (int)ViewBag.PuntosUsuario;
}

<!-- HEADER -->
<section class="tienda-hero" style="min-height: auto;">
    <div class="container py-5">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <a href="/Recompensas" class="text-white text-decoration-none opacity-75 d-inline-flex align-items-center mb-3 transition-all hover-opacity-100">
                    <i data-lucide="arrow-left" class="me-2" style="width: 18px; height: 18px; vertical-align: middle;"></i> Volver a la tienda
                </a>
                <h1 class="display-5 fw-black text-white mb-2">Mis Canjes</h1>
                <p class="text-white text-opacity-75 fs-6">
                    Aquí están todos tus vouchers. Presenta el código en el establecimiento para reclamar tu premio.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <div class="puntos-card-hero" style="display: inline-block;">
                    <div class="puntos-card-label">Puntos disponibles</div>
                    <div class="puntos-card-valor">@puntos</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i data-lucide="ticket" class="text-muted mb-3" style="width: 64px; height: 64px; stroke-width: 1.5;"></i>
                <h4 class="fw-bold mt-3">Aún no tienes canjes</h4>
                <p class="text-muted mb-4">Visita la tienda y canjea tus puntos por premios increíbles.</p>
                <a href="/Recompensas" class="btn btn-primary rounded-pill px-4 d-inline-flex align-items-center justify-content-center gap-2">
                    <i data-lucide="gift" style="width: 18px; height: 18px;"></i>Ir a la Tienda
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var c in Model)
                {
                    var esDisponible = c.Estado == "Disponible";
                    <div class="col-md-6 col-lg-4">
                        <div class="voucher-card @(!esDisponible ? "usado" : "")">
                            <div class="voucher-card-header">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="voucher-icon-box">
                                        <i data-lucide="ticket" style="width: 20px; height: 20px;"></i>
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0">@c.Recompensa?.Nombre</h6>
                                        <small class="text-muted">@c.FechaCanje.ToString("dd MMM yyyy, hh:mm tt")</small>
                                    </div>
                                </div>
                            </div>
                            <div class="voucher-card-body">
                                <div class="voucher-code-display @(!esDisponible ? "usado" : "")">
                                    <span class="fw-black">@c.CodigoVoucher</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="small text-muted d-inline-flex align-items-center">
                                        <i data-lucide="star" class="text-warning fill-warning me-1" style="width: 14px; height: 14px;"></i>@c.PuntosGastados pts
                                    </span>
                                    <span class="badge @(esDisponible ? "bg-success" : "bg-secondary") bg-opacity-10 @(esDisponible ? "text-success" : "text-secondary") rounded-pill px-3 d-inline-flex align-items-center gap-1">
                                        <i data-lucide="@(esDisponible ? "check-circle" : "x-circle")" style="width: 14px; height: 14px;"></i>
                                        @c.Estado
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
