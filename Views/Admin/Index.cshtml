@{
    ViewData["Title"] = "Panel de Administración";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ============================================
     HEADER ADMIN
     ============================================ -->
<section class="admin-header py-5">
    <div class="container">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="admin-icon-badge">
                <i data-lucide="shield-alert" style="width: 28px; height: 28px; stroke-width: 2;"></i>
            </div>
            <div>
                <h1 class="fw-black mb-0 display-6">Panel de Administración</h1>
                <p class="text-muted mb-0">Gestiona lugares, usuarios y reseñas de WebbyPoints</p>
            </div>
        </div>
    </div>
</section>

<!-- ============================================
     NAVEGACIÓN ADMIN
     ============================================ -->
<section class="pb-4">
    <div class="container">
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/Admin" class="btn btn-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="gauge" style="width: 18px; height: 18px;"></i>Dashboard
            </a>
            <a href="/Admin/Lugares" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="map-pin" style="width: 18px; height: 18px;"></i>Lugares
            </a>
            <a href="/Admin/Usuarios" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="users" style="width: 18px; height: 18px;"></i>Usuarios
            </a>
            <a href="/Admin/Reseñas" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="message-square" style="width: 18px; height: 18px;"></i>Reseñas
            </a>
        </div>

        <!-- Alerta de éxito -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm d-inline-flex align-items-center w-100" role="alert">
                <i data-lucide="check-circle" class="me-2 text-success" style="width: 20px; height: 20px;"></i>
                <div class="flex-grow-1">@TempData["Success"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="top: 50%; transform: translateY(-50%);"></button>
            </div>
        }

        <!-- ============================================
             ESTADÍSTICAS GENERALES
             ============================================ -->
        <div class="row g-4 mb-5">
            <div class="col-6 col-lg-3">
                <div class="admin-stat-card rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                            <i data-lucide="map-pin" style="width: 24px; height: 24px;"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-black">@ViewBag.TotalLugares</div>
                            <div class="text-muted small fw-medium">Lugares</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="admin-stat-card rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-success bg-opacity-10 text-success">
                            <i data-lucide="users" style="width: 24px; height: 24px;"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-black">@ViewBag.TotalUsuarios</div>
                            <div class="text-muted small fw-medium">Usuarios</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="admin-stat-card rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                            <i data-lucide="message-square" style="width: 24px; height: 24px;"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-black">@ViewBag.TotalReseñas</div>
                            <div class="text-muted small fw-medium">Reseñas</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="admin-stat-card rounded-4 p-4 h-100">
                    <div class="d-flex align-items-center gap-3">
                        <div class="stat-icon bg-danger bg-opacity-10 text-danger">
                            <i data-lucide="star" class="text-danger fill-danger" style="width: 24px; height: 24px;"></i>
                        </div>
                        <div>
                            <div class="fs-3 fw-black">@(((double)ViewBag.PromedioCalificacion).ToString("0.0"))</div>
                            <div class="text-muted small fw-medium">Calif. Promedio</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ============================================
             ACCIONES RÁPIDAS
             ============================================ -->
        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <a href="/Admin/CrearLugar" class="text-decoration-none">
                    <div class="admin-action-card rounded-4 p-4 h-100 text-center">
                        <div class="action-icon-wrapper bg-primary bg-opacity-10 mb-3 mx-auto">
                            <i data-lucide="plus" class="text-primary" style="width: 28px; height: 28px;"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Agregar Lugar</h5>
                        <p class="text-muted small mb-0">Registra un nuevo punto de interés para los estudiantes</p>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Admin/Usuarios" class="text-decoration-none">
                    <div class="admin-action-card rounded-4 p-4 h-100 text-center">
                        <div class="action-icon-wrapper bg-success bg-opacity-10 mb-3 mx-auto">
                            <i data-lucide="users" class="text-success" style="width: 28px; height: 28px;"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Ver Usuarios</h5>
                        <p class="text-muted small mb-0">Gestiona la comunidad de usuarios registrados</p>
                    </div>
                </a>
            </div>
            <div class="col-md-4">
                <a href="/Admin/Reseñas" class="text-decoration-none">
                    <div class="admin-action-card rounded-4 p-4 h-100 text-center">
                        <div class="action-icon-wrapper bg-warning bg-opacity-10 mb-3 mx-auto">
                            <i data-lucide="message-square" class="text-warning" style="width: 28px; height: 28px;"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Moderar Reseñas</h5>
                        <p class="text-muted small mb-0">Revisa y modera las opiniones de la comunidad</p>
                    </div>
                </a>
            </div>
        </div>

        <!-- ============================================
             ACTIVIDAD RECIENTE
             ============================================ -->
        <div class="row g-4">
            <!-- Últimos Usuarios -->
            <div class="col-lg-6">
                <div class="bg-white rounded-4 shadow-sm border p-4 h-100">
                    <h5 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="user-plus" class="text-success" style="width: 20px; height: 20px;"></i>Últimos Usuarios</h5>
                    @{
                        var ultimosUsuarios = ViewBag.UltimosUsuarios as List<WebbyPoints.Models.Usuario>;
                    }
                    @if (ultimosUsuarios != null && ultimosUsuarios.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var u in ultimosUsuarios)
                            {
                                <div class="list-group-item border-0 px-0 d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" 
                                         style="width: 40px; height: 40px; background: linear-gradient(135deg, #4f46e5, #7c3aed); font-size: 0.85rem;">
                                        @(u.Nombre.Length > 0 ? u.Nombre.Substring(0, 1).ToUpper() : "?")
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold">@u.Nombre</div>
                                        <div class="text-muted small">@u.Email</div>
                                    </div>
                                    <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">@u.Rango</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No hay usuarios aún.</p>
                    }
                </div>
            </div>

            <!-- Últimas Reseñas -->
            <div class="col-lg-6">
                <div class="bg-white rounded-4 shadow-sm border p-4 h-100">
                    <h5 class="fw-bold mb-3 d-flex align-items-center gap-2"><i data-lucide="message-square" class="text-warning" style="width: 20px; height: 20px;"></i>Últimas Reseñas</h5>
                    @{
                        var ultimasReseñas = ViewBag.UltimasReseñas as List<WebbyPoints.Models.Reseña>;
                    }
                    @if (ultimasReseñas != null && ultimasReseñas.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var r in ultimasReseñas)
                            {
                                <div class="list-group-item border-0 px-0">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <div class="fw-semibold small">@r.Usuario?.Nombre</div>
                                        <div class="d-flex gap-1">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i data-lucide="star" style="width: 14px; height: 14px;" class="@(i <= r.Calificacion ? "text-warning fill-warning" : "text-muted opacity-25")"></i>
                                            }
                                        </div>
                                    </div>
                                    <div class="text-muted small mb-1">en <strong>@r.PuntoInteres?.Nombre</strong></div>
                                    <div class="small">@(r.Comentario?.Length > 80 ? r.Comentario.Substring(0, 80) + "..." : r.Comentario)</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No hay reseñas aún.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .admin-header {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef1ff 100%);
        border-bottom: 1px solid rgba(79, 70, 229, 0.08);
    }
    .admin-icon-badge {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 1.5rem;
    }
    .admin-stat-card {
        background: white;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        transition: all 0.3s ease;
    }
    .admin-stat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.08); }
    .stat-icon {
        width: 48px; height: 48px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
    }
    .admin-action-card {
        background: white;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        transition: all 0.3s ease;
        cursor: pointer;
    }
    .admin-action-card:hover { transform: translateY(-6px); box-shadow: 0 12px 30px rgba(0,0,0,0.1); }
    .action-icon-wrapper {
        width: 64px; height: 64px; border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
    }
</style>
