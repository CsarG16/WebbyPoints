@model List<WebbyPoints.Models.PuntoInteres>
@{
    ViewData["Title"] = "Gestión de Lugares";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HEADER -->
<section class="admin-header py-5">
    <div class="container">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="admin-icon-badge">
                <i data-lucide="map-pin" style="width: 28px; height: 28px; stroke-width: 2;"></i>
            </div>
            <div>
                <h1 class="fw-black mb-0 display-6">Gestión de Lugares</h1>
                <p class="text-muted mb-0">Agrega, edita o elimina puntos de interés</p>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <!-- Nav Admin -->
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/Admin" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="gauge" style="width: 18px; height: 18px;"></i>Dashboard
            </a>
            <a href="/Admin/Lugares" class="btn btn-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="map-pin" style="width: 18px; height: 18px;"></i>Lugares
            </a>
            <a href="/Admin/Usuarios" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="users" style="width: 18px; height: 18px;"></i>Usuarios
            </a>
            <a href="/Admin/Reseñas" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold d-inline-flex align-items-center gap-2">
                <i data-lucide="message-square" style="width: 18px; height: 18px;"></i>Reseñas
            </a>
        </div>

        <!-- Alerta de éxito -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm d-inline-flex align-items-center w-100" role="alert">
                <i data-lucide="check-circle" class="me-2 text-success" style="width: 20px; height: 20px;"></i>
                <div class="flex-grow-1">@TempData["Success"]</div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" style="top: 50%; transform: translateY(-50%);"></button>
            </div>
        }

        <!-- Botón Agregar -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">@Model.Count lugares registrados</h5>
            <a href="/Admin/CrearLugar" class="btn btn-primary rounded-pill px-4 d-inline-flex align-items-center gap-2">
                <i data-lucide="plus" style="width: 18px; height: 18px;"></i>Agregar Lugar
            </a>
        </div>

        <!-- Tabla de Lugares -->
        <div class="bg-white rounded-4 shadow-sm border overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 ps-4 py-3 fw-semibold">ID</th>
                            <th class="border-0 py-3 fw-semibold">Nombre</th>
                            <th class="border-0 py-3 fw-semibold">Categoría</th>
                            <th class="border-0 py-3 fw-semibold">Plan</th>
                            <th class="border-0 py-3 fw-semibold text-center">Calificación</th>
                            <th class="border-0 py-3 fw-semibold text-center">Reseñas</th>
                            <th class="border-0 pe-4 py-3 fw-semibold text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lugar in Model)
                        {
                            <tr>
                                <td class="ps-4 text-muted small">#@lugar.Id</td>
                                <td>
                                    <div class="fw-semibold">@lugar.Nombre</div>
                                    <div class="text-muted small">@lugar.Ubicacion</div>
                                </td>
                                <td><span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">@lugar.Categoria</span></td>
                                <td>
                                    @{
                                        var planBadge = lugar.PlanTipo?.ToLower() switch
                                        {
                                            "solo" => "primary",
                                            "pareja" => "danger",
                                            "amigos" => "warning",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@planBadge bg-opacity-10 text-@planBadge rounded-pill">@lugar.PlanTipo</span>
                                </td>
                                <td class="text-center">
                                    <span class="d-inline-flex align-items-center justify-content-center w-100 gap-1">
                                        <i data-lucide="star" class="text-warning fill-warning" style="width: 14px; height: 14px;"></i>@lugar.Calificacion.ToString("0.0")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark">@lugar.Reseñas.Count</span>
                                </td>
                                <td class="pe-4 text-end">
                                    <a href="/Admin/EditarLugar/@lugar.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1 d-inline-flex align-items-center gap-1">
                                        <i data-lucide="edit-2" style="width: 14px; height: 14px;"></i>Editar
                                    </a>
                                    <form method="post" action="/Admin/EliminarLugar/@lugar.Id" class="d-inline"
                                          onsubmit="return confirm('¿Estás seguro de que quieres eliminar este lugar? Se borrarán también sus reseñas.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@lugar.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3 d-inline-flex align-items-center gap-1">
                                            <i data-lucide="trash-2" style="width: 14px; height: 14px;"></i>Eliminar
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<style>
    .admin-header {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef1ff 100%);
        border-bottom: 1px solid rgba(79, 70, 229, 0.08);
    }
    .admin-icon-badge {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 1.5rem;
    }
</style>
