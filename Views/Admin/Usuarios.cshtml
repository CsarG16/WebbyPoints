@model List<WebbyPoints.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HEADER -->
<section class="admin-header py-5">
    <div class="container">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="admin-icon-badge">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h1 class="fw-black mb-0 display-6">Gestión de Usuarios</h1>
                <p class="text-muted mb-0">Visualiza la comunidad de usuarios registrados</p>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <!-- Nav Admin -->
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/Admin" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a href="/Admin/Lugares" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-geo-alt me-1"></i>Lugares
            </a>
            <a href="/Admin/Usuarios" class="btn btn-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-people me-1"></i>Usuarios
            </a>
            <a href="/Admin/Reseñas" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-chat-square-text me-1"></i>Reseñas
            </a>
        </div>

        <h5 class="fw-bold mb-4">@Model.Count usuarios registrados</h5>

        <!-- Tabla de Usuarios -->
        <div class="bg-white rounded-4 shadow-sm border overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 ps-4 py-3 fw-semibold">Usuario</th>
                            <th class="border-0 py-3 fw-semibold">Email</th>
                            <th class="border-0 py-3 fw-semibold">Universidad</th>
                            <th class="border-0 py-3 fw-semibold text-center">Puntos</th>
                            <th class="border-0 py-3 fw-semibold text-center">Rango</th>
                            <th class="border-0 py-3 fw-semibold text-center">Reseñas</th>
                            <th class="border-0 py-3 fw-semibold text-center">Rol</th>
                            <th class="border-0 pe-4 py-3 fw-semibold">Registro</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" 
                                             style="width: 38px; height: 38px; background: linear-gradient(135deg, #4f46e5, #7c3aed); font-size: 0.8rem; flex-shrink: 0;">
                                            @(u.Nombre.Length > 0 ? u.Nombre.Substring(0, 1).ToUpper() : "?")
                                        </div>
                                        <div>
                                            <div class="fw-semibold">@u.Nombre</div>
                                            <div class="text-muted small">@u.Carrera</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="small">@u.Email</td>
                                <td class="small">@u.Universidad</td>
                                <td class="text-center">
                                    <span class="fw-bold text-primary">@u.Puntos</span>
                                </td>
                                <td class="text-center">
                                    @{
                                        var rangoBadge = u.Rango switch
                                        {
                                            "Leyenda" => "danger",
                                            "Experto" => "warning",
                                            "Local" => "success",
                                            "Explorador" => "info",
                                            "Administrador" => "dark",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@rangoBadge bg-opacity-10 text-@rangoBadge rounded-pill">@u.Rango</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark">@u.Reseñas.Count</span>
                                </td>
                                <td class="text-center">
                                    @if (u.EsAdmin)
                                    {
                                        <span class="badge bg-dark rounded-pill"><i class="bi bi-shield-lock me-1"></i>Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill">Usuario</span>
                                    }
                                </td>
                                <td class="pe-4 text-muted small">@u.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<style>
    .admin-header {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef1ff 100%);
        border-bottom: 1px solid rgba(79, 70, 229, 0.08);
    }
    .admin-icon-badge {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 1.5rem;
    }
</style>
