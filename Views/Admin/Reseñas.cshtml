@model List<WebbyPoints.Models.Reseña>
@{
    ViewData["Title"] = "Moderación de Reseñas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HEADER -->
<section class="admin-header py-5">
    <div class="container">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div class="admin-icon-badge">
                <i class="bi bi-chat-square-text-fill"></i>
            </div>
            <div>
                <h1 class="fw-black mb-0 display-6">Moderación de Reseñas</h1>
                <p class="text-muted mb-0">Revisa y modera las opiniones de la comunidad</p>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <!-- Nav Admin -->
        <div class="d-flex flex-wrap gap-2 mb-4">
            <a href="/Admin" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-speedometer2 me-1"></i>Dashboard
            </a>
            <a href="/Admin/Lugares" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-geo-alt me-1"></i>Lugares
            </a>
            <a href="/Admin/Usuarios" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-people me-1"></i>Usuarios
            </a>
            <a href="/Admin/Reseñas" class="btn btn-dark rounded-pill px-4 py-2 fw-semibold">
                <i class="bi bi-chat-square-text me-1"></i>Reseñas
            </a>
        </div>

        <!-- Alerta de éxito -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <h5 class="fw-bold mb-4">@Model.Count reseñas en total</h5>

        @if (Model.Any())
        {
            <div class="row g-3">
                @foreach (var r in Model)
                {
                    <div class="col-12">
                        <div class="bg-white rounded-4 shadow-sm border p-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="d-flex gap-3 flex-grow-1">
                                    <!-- Avatar -->
                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-white" 
                                         style="width: 44px; height: 44px; background: linear-gradient(135deg, #4f46e5, #7c3aed); font-size: 0.9rem; flex-shrink: 0;">
                                        @(r.Usuario?.Nombre?.Length > 0 ? r.Usuario.Nombre.Substring(0, 1).ToUpper() : "?")
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center gap-2 mb-1">
                                            <span class="fw-bold">@r.Usuario?.Nombre</span>
                                            <span class="text-muted small">·</span>
                                            <span class="text-muted small">@r.FechaPublicacion.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                        <div class="mb-2">
                                            <span class="text-muted small">en </span>
                                            <a href="/Home/Detalle/@r.PuntoInteresId" class="fw-semibold text-primary text-decoration-none small">
                                                @r.PuntoInteres?.Nombre
                                            </a>
                                        </div>
                                        <!-- Estrellas -->
                                        <div class="mb-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi bi-star-fill @(i <= r.Calificacion ? "text-warning" : "text-muted opacity-25")"></i>
                                            }
                                        </div>
                                        <p class="mb-0 text-dark">@r.Comentario</p>
                                    </div>
                                </div>
                                
                                <!-- Eliminar -->
                                <form method="post" action="/Admin/EliminarReseña/@r.Id" 
                                      onsubmit="return confirm('¿Eliminar esta reseña de @r.Usuario?.Nombre?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="bi bi-trash me-1"></i>Eliminar
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
                <i class="bi bi-chat-square-text display-3 text-muted opacity-25 mb-3 d-block"></i>
                <h4 class="fw-bold">No hay reseñas aún</h4>
                <p class="text-muted">Las reseñas de la comunidad aparecerán aquí.</p>
            </div>
        }
    </div>
</section>

<style>
    .admin-header {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef1ff 100%);
        border-bottom: 1px solid rgba(79, 70, 229, 0.08);
    }
    .admin-icon-badge {
        width: 56px; height: 56px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border-radius: 16px;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 1.5rem;
    }
</style>
